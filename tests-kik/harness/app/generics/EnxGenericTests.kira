// EnxGenericTests.kira — Deep Result<T, E> test suite.
// Covers: Result<Int,E>, Result<struct,E>, Result<enum,E>, Result<[Int],E>;
// both Ok and Error paths; chained matching; pipeline combinator; Results in
// struct fields; Results in array elements matched via borrow-param helper;
// error-code helpers; combined patterns; trap tests.
// All top-level names use prefix enxG / EnxG.

// ---------------------------------------------------------------------------
// Error enum and value types
// ---------------------------------------------------------------------------

enum EnxGErr {
    DivByZero
    Overflow
    NotFound
    Empty
    BadInput
}

enum EnxGTone {
    Warm
    Cool
    Neutral
    Vivid
}

struct EnxGRect {
    var w: Int
    var h: Int

    function area() -> Int {
        return self.w * self.h
    }
}

// Stores a Result in a struct field for later matching.
struct EnxGSlot {
    var tag: Int
    var r: Result<Int, EnxGErr>
}

// ---------------------------------------------------------------------------
// Helper functions
// ---------------------------------------------------------------------------

// Error-code helper: all negative so they fold distinctly from success values.
function enxGErrCode(e: borrow EnxGErr) -> Int {
    match e {
        DivByZero -> { return 0 - 1 }
        Overflow  -> { return 0 - 2 }
        NotFound  -> { return 0 - 3 }
        Empty     -> { return 0 - 4 }
        BadInput  -> { return 0 - 5 }
    }
}

function enxGToneVal(t: borrow EnxGTone) -> Int {
    match t {
        Warm    -> { return 100 }
        Cool    -> { return 200 }
        Neutral -> { return 300 }
        Vivid   -> { return 400 }
    }
}

// --- Result<Int, EnxGErr> ---------------------------------------------------

// Safe integer division: Error(DivByZero) if b==0, Error(BadInput) if a<0.
function enxGSafeDiv(a: Int, b: Int) -> Result<Int, EnxGErr> {
    if b == 0 {
        return Result.Error(EnxGErr.DivByZero)
    }
    if a < 0 {
        return Result.Error(EnxGErr.BadInput)
    }
    return Result.Ok(a / b)
}

// Fold a borrowed Result<Int, EnxGErr> to Int. Using a borrow-param function
// is the required pattern for matching array elements (KSEM104 forbids direct
// `match arr[i]`).
function enxGResultIntVal(r: borrow Result<Int, EnxGErr>) -> Int {
    match r {
        Ok(x)    -> { return x }
        Error(e) -> { return enxGErrCode(e) }
    }
}

// Returns 1 if r is an Error, 0 if Ok. Used to avoid matching arr[i] directly.
function enxGIsError(r: borrow Result<Int, EnxGErr>) -> Int {
    match r {
        Ok(x)    -> { return 0 }
        Error(e) -> { return 1 }
    }
}

// --- Result<EnxGRect, EnxGErr> ----------------------------------------------

// Makes a rect: errors if w or h <= 0, or if area > 10000.
function enxGMakeRect(w: Int, h: Int) -> Result<EnxGRect, EnxGErr> {
    if w <= 0 || h <= 0 {
        return Result.Error(EnxGErr.BadInput)
    }
    if w * h > 10000 {
        return Result.Error(EnxGErr.Overflow)
    }
    return Result.Ok(EnxGRect { w: w, h: h })
}

function enxGRectResultArea(r: borrow Result<EnxGRect, EnxGErr>) -> Int {
    match r {
        Ok(rect) -> { return rect.area() }
        Error(e) -> { return enxGErrCode(e) }
    }
}

// --- Result<EnxGTone, EnxGErr> ---------------------------------------------

// Maps 0->Warm, 1->Cool, 2->Neutral, 3->Vivid, else Error(BadInput).
function enxGColorResult(i: Int) -> Result<EnxGTone, EnxGErr> {
    switch i {
        case 0 { return Result.Ok(EnxGTone.Warm) }
        case 1 { return Result.Ok(EnxGTone.Cool) }
        case 2 { return Result.Ok(EnxGTone.Neutral) }
        case 3 { return Result.Ok(EnxGTone.Vivid) }
        default { return Result.Error(EnxGErr.BadInput) }
    }
}

function enxGToneResultVal(r: borrow Result<EnxGTone, EnxGErr>) -> Int {
    match r {
        Ok(t)    -> { return enxGToneVal(t) }
        Error(e) -> { return enxGErrCode(e) }
    }
}

// --- Result<[Int], EnxGErr> ------------------------------------------------

// Builds [0, 3, 6, ..., (n-1)*3]. Error(Empty) if n<=0, Error(Overflow) if n>100.
function enxGBuildRange(n: Int) -> Result<[Int], EnxGErr> {
    if n <= 0 {
        return Result.Error(EnxGErr.Empty)
    }
    if n > 100 {
        return Result.Error(EnxGErr.Overflow)
    }
    var xs: [Int] = []
    var i = 0
    while i < n {
        xs.append(i * 3)
        i = i + 1
    }
    return Result.Ok(move xs)
}

// --- Result in struct fields ------------------------------------------------

function enxGSlotVal(slot: borrow EnxGSlot) -> Int {
    match slot.r {
        Ok(x)    -> { return x + slot.tag }
        Error(e) -> { return slot.tag + enxGErrCode(e) }
    }
}

// --- Chained Result matching -----------------------------------------------

// Three-level chain: each Ok feeds the next fallible call.
function enxGChain3(a: Int, b: Int, c: Int) -> Int {
    let r1 = enxGSafeDiv(a, b)
    match r1 {
        Ok(x) -> {
            let r2 = enxGSafeDiv(x + 10, c)
            match r2 {
                Ok(y) -> {
                    let r3 = enxGSafeDiv(y + 5, 2)
                    match r3 {
                        Ok(z)    -> { return x + y + z }
                        Error(e) -> { return enxGErrCode(e) }
                    }
                }
                Error(e) -> { return enxGErrCode(e) }
            }
        }
        Error(e) -> { return enxGErrCode(e) }
    }
}

// --- Pipeline combinator ---------------------------------------------------

// Ok advances, Error propagates unchanged.
function enxGStep(r: Result<Int, EnxGErr>, k: Int) -> Result<Int, EnxGErr> {
    match r {
        Ok(x)    -> { return enxGSafeDiv(x + k, k) }
        Error(e) -> { return Result.Error(e) }
    }
}

function enxGPipeline(seed: Int, k1: Int, k2: Int, k3: Int) -> Int {
    let r0 = enxGSafeDiv(seed, 1)
    let r1 = enxGStep(move r0, k1)
    let r2 = enxGStep(move r1, k2)
    let r3 = enxGStep(move r2, k3)
    match r3 {
        Ok(v)    -> { return v }
        Error(e) -> { return enxGErrCode(e) }
    }
}

// ---------------------------------------------------------------------------
// T = Int tests
// ---------------------------------------------------------------------------

// enxGSafeDiv(90, 9) -> Ok(10)
Test EnxGDivOkBasic {
    test {
        let r = enxGSafeDiv(90, 9)
        var out = 0
        match r {
            Ok(x)    -> { out = x }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

// enxGSafeDiv(100, 7) -> Ok(14) (truncated)
Test EnxGDivOkTruncated {
    test {
        let r = enxGSafeDiv(100, 7)
        var out = 0
        match r {
            Ok(x)    -> { out = x }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(14); return e }
}

// enxGSafeDiv(50, 0) -> Error(DivByZero) -> -1
Test EnxGDivErrDivByZero {
    test {
        let r = enxGSafeDiv(50, 0)
        var out = 0
        match r {
            Ok(x)    -> { out = x }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 1); return e }
}

// enxGSafeDiv(-10, 2) -> Error(BadInput) -> -5
Test EnxGDivErrBadInput {
    test {
        let r = enxGSafeDiv(0 - 10, 2)
        var out = 0
        match r {
            Ok(x)    -> { out = x }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 5); return e }
}

// enxGSafeDiv(0, 5) -> Ok(0)
Test EnxGDivZeroNumerator {
    test {
        let r = enxGSafeDiv(0, 5)
        var out = 999
        match r {
            Ok(x)    -> { out = x }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

// enxGSafeDiv(42, 1) -> Ok(42)
Test EnxGDivUnitDivisor {
    test { return enxGResultIntVal(enxGSafeDiv(42, 1)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

// enxGSafeDiv(999, 9) -> Ok(111)
Test EnxGDivLargeOk {
    test { return enxGResultIntVal(enxGSafeDiv(999, 9)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(111); return e }
}

// sum enxGSafeDiv(120, i+1) for i=0..11 (all Ok):
// 120/1+120/2+120/3+120/4+120/5+120/6+120/7+120/8+120/9+120/10+120/11+120/12
// =120+60+40+30+24+20+17+15+13+12+10+10=371
Test EnxGDivLoopFold12 {
    test {
        var acc = 0
        var i = 0
        while i < 12 {
            acc = acc + enxGResultIntVal(enxGSafeDiv(120, i + 1))
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(371); return e }
}

// Count Error results in enxGSafeDiv(i-3, 2) for i=0..5:
// i=0:a=-3<0->Error, i=1:a=-2->Error, i=2:a=-1->Error, i=3..5:Ok -> count=3
Test EnxGDivErrorCount {
    test {
        var count = 0
        var i = 0
        while i < 6 {
            let r = enxGSafeDiv(i - 3, 2)
            var isErr = 0
            match r {
                Ok(x)    -> { isErr = 0 }
                Error(e) -> { isErr = 1 }
            }
            count = count + isErr
            i = i + 1
        }
        return count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

// Sum of all 5 error codes: -1-2-3-4-5 = -15
Test EnxGAllErrCodeSum {
    test {
        let a = enxGErrCode(EnxGErr.DivByZero)
        let b = enxGErrCode(EnxGErr.Overflow)
        let c = enxGErrCode(EnxGErr.NotFound)
        let d = enxGErrCode(EnxGErr.Empty)
        let f = enxGErrCode(EnxGErr.BadInput)
        return a + b + c + d + f
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 15); return e }
}

// Inline match with both paths covered: Ok path
Test EnxGInlineMatchOk {
    test {
        let r = enxGSafeDiv(56, 8)
        var out = 0
        match r {
            Ok(x)    -> { out = x }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

// Inline match with both paths covered: Error path
Test EnxGInlineMatchErr {
    test {
        let r = enxGSafeDiv(0 - 1, 5)
        var out = 0
        match r {
            Ok(x)    -> { out = x }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 5); return e }
}

