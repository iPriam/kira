// colorResult(0) -> Ok(Warm) -> 100
Test EnxGToneWarm {
    test { return enxGToneResultVal(enxGColorResult(0)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(100); return e }
}

// colorResult(1) -> Ok(Cool) -> 200
Test EnxGToneCool {
    test { return enxGToneResultVal(enxGColorResult(1)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(200); return e }
}

// colorResult(2) -> Ok(Neutral) -> 300
Test EnxGToneNeutral {
    test { return enxGToneResultVal(enxGColorResult(2)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(300); return e }
}

// colorResult(3) -> Ok(Vivid) -> 400
Test EnxGToneVivid {
    test { return enxGToneResultVal(enxGColorResult(3)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(400); return e }
}

// colorResult(4) -> Error(BadInput) -> -5
Test EnxGToneBadInput {
    test { return enxGToneResultVal(enxGColorResult(4)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 5); return e }
}

// Fold colorResult(i%5) for i=0..15 (16 values):
// Cycle 0..4: 100+200+300+400-5=995; 3 full (0..14)=2985; i=15:15%5=0->Warm->100
// total=3085
Test EnxGToneFold16 {
    test {
        var acc = 0
        var i = 0
        while i < 16 {
            acc = acc + enxGToneResultVal(enxGColorResult(i % 5))
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3085); return e }
}

// Count non-error tones in i=0..19: i%5 in {0,1,2,3} -> 4 per 5-cycle -> 16
Test EnxGToneNonErrorCount {
    test {
        var count = 0
        var i = 0
        while i < 20 {
            let r = enxGColorResult(i % 5)
            var ok = 0
            match r {
                Ok(t)    -> { ok = 1 }
                Error(e) -> { ok = 0 }
            }
            count = count + ok
            i = i + 1
        }
        return count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(16); return e }
}

// Fold colorResult(i%5) for i=0..11:
// cycle 0..4: 995; cycle 5..9: 995; i=10:0->100; i=11:1->200
// total=995+995+100+200=2290
Test EnxGToneFold12 {
    test {
        var acc = 0
        var i = 0
        while i < 12 {
            acc = acc + enxGToneResultVal(enxGColorResult(i % 5))
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(2290); return e }
}

// Inline double-match: Ok(Vivid) inner tone value
Test EnxGToneInlineDouble {
    test {
        let r = enxGColorResult(3)
        var out = 0
        match r {
            Ok(t)    -> { out = enxGToneVal(t) }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(400); return e }
}

// ---------------------------------------------------------------------------
// T = owned array (Result<[Int], EnxGErr>) tests
// ---------------------------------------------------------------------------

// buildRange(5) -> Ok([0,3,6,9,12]) -> sum=30
Test EnxGRangeOk5 {
    test {
        let r = enxGBuildRange(5)
        var out = 0
        match r {
            Ok(xs) -> {
                var i = 0
                while i < xs.count {
                    out = out + xs[i]
                    i = i + 1
                }
            }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

// buildRange(10) -> Ok([0,3,6,...,27]) -> sum=3*(0+1+...+9)=3*45=135
Test EnxGRangeOk10 {
