        let r = enxGBuildRange(10)
        var out = 0
        match r {
            Ok(xs) -> {
                var i = 0
                while i < xs.count {
                    out = out + xs[i]
                    i = i + 1
                }
            }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(135); return e }
}

