// sum buildRange(m) for m=1..6:
// 0 + 3 + 9 + 18 + 30 + 45 = 105
Test EnxGRangeSumFold {
    test {
        var total = 0
        var m = 1
        while m <= 6 {
            let r = enxGBuildRange(m)
            match r {
                Ok(xs) -> {
                    var i = 0
                    while i < xs.count {
                        total = total + xs[i]
                        i = i + 1
                    }
                }
                Error(e) -> { total = total + enxGErrCode(e) }
            }
            m = m + 1
        }
        return total
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(105); return e }
}

// buildRange(3) -> count = 3
Test EnxGRangeCount {
    test {
        let r = enxGBuildRange(3)
        var out = 0
        match r {
            Ok(xs)   -> { out = xs.count }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

// buildRange(1) -> Ok([0]) -> sum=0
Test EnxGRangeSingleElem {
    test {
        let r = enxGBuildRange(1)
        var out = 0
        match r {
            Ok(xs) -> {
                out = xs[0]
            }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

// ---------------------------------------------------------------------------
// Chained matching tests
// ---------------------------------------------------------------------------

// chain3(100, 5, 4):
// r1=Ok(20); r2=safeDiv(30,4)=Ok(7); r3=safeDiv(12,2)=Ok(6); return 20+7+6=33
Test EnxGChain3Success {
    test { return enxGChain3(100, 5, 4) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(33); return e }
}

// chain3(100, 0, 4): r1=Error(DivByZero) -> -1
Test EnxGChain3ErrStep1 {
    test { return enxGChain3(100, 0, 4) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 1); return e }
}

// chain3(100, 5, 0): r1=Ok(20); r2=safeDiv(30,0)=Error(DivByZero) -> -1
Test EnxGChain3ErrStep2 {
    test { return enxGChain3(100, 5, 0) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 1); return e }
}

// chain3(0, 5, 4): r1=Ok(0); r2=safeDiv(10,4)=Ok(2); r3=safeDiv(7,2)=Ok(3); return 0+2+3=5
Test EnxGChain3ZeroSeed {
    test { return enxGChain3(0, 5, 4) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

// chain3(-1, 5, 4): r1=Error(BadInput) -> -5
Test EnxGChain3BadInput {
    test { return enxGChain3(0 - 1, 5, 4) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 5); return e }
}

// sum chain3 results for multiple inputs: 33 + (-1) + (-1) + 5 = 36
Test EnxGChain3SumFold {
    test {
        let v1 = enxGChain3(100, 5, 4)
        let v2 = enxGChain3(100, 0, 4)
        let v3 = enxGChain3(100, 5, 0)
        let v4 = enxGChain3(0, 5, 4)
        return v1 + v2 + v3 + v4
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(36); return e }
}

// ---------------------------------------------------------------------------
// Pipeline combinator tests
// ---------------------------------------------------------------------------

// pipeline(12, 4, 2, 3):
// r0=Ok(12); r1=step(12,4)=safeDiv(16,4)=Ok(4);
// r2=step(4,2)=safeDiv(6,2)=Ok(3); r3=step(3,3)=safeDiv(6,3)=Ok(2); return 2
Test EnxGPipelineSuccess {
    test { return enxGPipeline(12, 4, 2, 3) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(2); return e }
}

// pipeline(20, 0, 3, 5): k1=0 causes DivByZero at step1, propagates -> -1
Test EnxGPipelineErrPropagates {
    test { return enxGPipeline(20, 0, 3, 5) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 1); return e }
}

// pipeline(6, 3, 2, 4):
// r0=Ok(6); r1=safeDiv(9,3)=Ok(3); r2=safeDiv(5,2)=Ok(2); r3=safeDiv(6,4)=Ok(1); return 1
Test EnxGPipelineSmallValues {
    test { return enxGPipeline(6, 3, 2, 4) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

// Two-step manual pipeline using enxGStep
// r0=safeDiv(10,1)=Ok(10); r1=step(Ok(10),5)=safeDiv(15,5)=Ok(3);
// r2=step(Ok(3),3)=safeDiv(6,3)=Ok(2); final=2
Test EnxGStepTwoSteps {
    test {
        let r0 = enxGSafeDiv(10, 1)
        let r1 = enxGStep(move r0, 5)
        let r2 = enxGStep(move r1, 3)
        var out = 0
        match r2 {
            Ok(v)    -> { out = v }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(2); return e }
}

// ---------------------------------------------------------------------------
// Result stored in struct fields, matched via borrow
// ---------------------------------------------------------------------------

// slot{10, Ok(5)} -> 5+10=15
Test EnxGSlotOk {
    test {
        let slot = EnxGSlot { tag: 10, r: Result.Ok(5) }
        return enxGSlotVal(slot)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(15); return e }
}

// slot{10, Error(DivByZero)} -> 10+(-1)=9
Test EnxGSlotErr {
    test {
        let slot = EnxGSlot { tag: 10, r: Result.Error(EnxGErr.DivByZero) }
        return enxGSlotVal(slot)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(9); return e }
}

// slot{0, Error(BadInput)} -> 0+(-5)=-5
Test EnxGSlotErrBadInput {
    test {
        let slot = EnxGSlot { tag: 0, r: Result.Error(EnxGErr.BadInput) }
        return enxGSlotVal(slot)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 5); return e }
}

// Fold slots: s=0..9, slot{s, safeDiv(200,s+1)} (all Ok, b>=1>0, a=200>=0)
// enxGSlotVal = 200/(s+1) + s
// s=0:200, s=1:101, s=2:68, s=3:53, s=4:44, s=5:38, s=6:34, s=7:32, s=8:30, s=9:29
// sum=629
Test EnxGSlotFold {
    test {
        var acc = 0
        var s = 0
        while s < 10 {
            let slot = EnxGSlot { tag: s, r: enxGSafeDiv(200, s + 1) }
            acc = acc + enxGSlotVal(slot)
            s = s + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(629); return e }
}

// Mixed slots: some Ok, some Error, fold values
// [slot{1,Ok(10)}, slot{2,Error(DivByZero)}, slot{3,Ok(20)}, slot{4,Error(Empty)}]
// values: 10+1=11, 2-1=1, 20+3=23, 4-4=0 -> sum=35
Test EnxGSlotMixedFold {
    test {
        var slots: [EnxGSlot] = []
        slots.append(EnxGSlot { tag: 1, r: Result.Ok(10) })
        slots.append(EnxGSlot { tag: 2, r: Result.Error(EnxGErr.DivByZero) })
        slots.append(EnxGSlot { tag: 3, r: Result.Ok(20) })
        slots.append(EnxGSlot { tag: 4, r: Result.Error(EnxGErr.Empty) })
        var acc = 0
        var j = 0
        while j < slots.count {
            acc = acc + enxGSlotVal(slots[j])
            j = j + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(35); return e }
}

// ---------------------------------------------------------------------------
// Result stored in array elements, matched via borrow-param helper
// ---------------------------------------------------------------------------

// Build [Result<Int,EnxGErr>]: i=0..9, i%3==2 -> Error(NotFound), else Ok(i*5)
// i=0:Ok(0), i=1:Ok(5), i=2:Err(-3), i=3:Ok(15), i=4:Ok(20),
// i=5:Err(-3), i=6:Ok(30), i=7:Ok(35), i=8:Err(-3), i=9:Ok(45)
// sum=0+5-3+15+20-3+30+35-3+45=141
Test EnxGResultArrayFold {
    test {
        var results: [Result<Int, EnxGErr>] = []
        var i = 0
        while i < 10 {
            if i % 3 == 2 {
                let errItem: Result<Int, EnxGErr> = Result.Error(EnxGErr.NotFound)
                results.append(move errItem)
            } else {
                let okItem: Result<Int, EnxGErr> = Result.Ok(i * 5)
                results.append(move okItem)
            }
            i = i + 1
        }
        var acc = 0
        var j = 0
        while j < results.count {
            acc = acc + enxGResultIntVal(results[j])
            j = j + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(141); return e }
}

// Build results from safeDiv, then sum: safeDiv(100, j+1) for j=0..5 (all Ok)
// 100/1+100/2+100/3+100/4+100/5+100/6 = 100+50+33+25+20+16 = 244
Test EnxGResultArrayDivFold {
    test {
        var results: [Result<Int, EnxGErr>] = []
        var j = 0
        while j < 6 {
            results.append(enxGSafeDiv(100, j + 1))
            j = j + 1
        }
        var acc = 0
        var k = 0
        while k < results.count {
            acc = acc + enxGResultIntVal(results[k])
            k = k + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(244); return e }
}

// Mix Ok and Error in result array, count errors
// safeDiv(i-5, 2) for i=0..9: i<5 -> BadInput (-5 each); i>=5 -> Ok
// errors: i=0,1,2,3,4 -> 5 errors
Test EnxGResultArrayCountErrors {
    test {
        var results: [Result<Int, EnxGErr>] = []
        var i = 0
        while i < 10 {
            results.append(enxGSafeDiv(i - 5, 2))
            i = i + 1
        }
        var errCount = 0
        var j = 0
        while j < results.count {
            errCount = errCount + enxGIsError(results[j])
            j = j + 1
        }
        return errCount
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

// ---------------------------------------------------------------------------
// Additional combinations
// ---------------------------------------------------------------------------

// Combine T=Int and T=struct in one test
// safeDiv(100,5)=Ok(20) plus makeRect(4,5)->area=20; total=40
Test EnxGCombineIntAndRect {
    test {
        let ri = enxGSafeDiv(100, 5)
        let rr = enxGMakeRect(4, 5)
        var vi = 0
        match ri {
            Ok(x)    -> { vi = x }
            Error(e) -> { vi = enxGErrCode(e) }
        }
        var vr = 0
        match rr {
            Ok(rect) -> { vr = rect.area() }
            Error(e) -> { vr = enxGErrCode(e) }
        }
        return vi + vr
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(40); return e }
}

// Combine T=enum and T=array
// colorResult(2)->Ok(Neutral)->300 + sum of buildRange(3)->[0,3,6]=9; total=309
Test EnxGCombineToneAndRange {
    test {
        let tone = enxGToneResultVal(enxGColorResult(2))
        let rng = enxGBuildRange(3)
        var rngSum = 0
        match rng {
            Ok(xs) -> {
                var i = 0
                while i < xs.count {
                    rngSum = rngSum + xs[i]
                    i = i + 1
                }
            }
            Error(e) -> { rngSum = enxGErrCode(e) }
        }
        return tone + rngSum
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(309); return e }
}

// Error path combines: all errors -> DivByZero(-1)+BadInput(-5)+Empty(-4)+Overflow(-2)=-12
Test EnxGCombineAllErrors {
    test {
        let e1 = enxGResultIntVal(enxGSafeDiv(10, 0))
        let e2 = enxGResultIntVal(enxGSafeDiv(0 - 5, 1))
        let e3 = enxGRectResultArea(enxGMakeRect(0, 5))
        var e4 = 0
        let r4 = enxGBuildRange(0)
        match r4 {
            Ok(xs)   -> { e4 = xs.count }
            Error(e) -> { e4 = enxGErrCode(e) }
        }
        return e1 + e2 + e3 + e4
    }
    // -1 + -5 + -5 + -4 = -15
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 15); return e }
}

// Nested Ok: chain feeds rect
// safeDiv(15,3)=Ok(5) -> makeRect(5,4)=Ok->area=20
Test EnxGChainFeedsRect {
    test {
        let r1 = enxGSafeDiv(15, 3)
        var out = 0
        match r1 {
            Ok(x) -> {
                let r2 = enxGMakeRect(x, 4)
                match r2 {
                    Ok(rect) -> { out = rect.area() }
                    Error(e) -> { out = enxGErrCode(e) }
                }
            }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(20); return e }
}

// Multiple independent results combined
// safeDiv(100,4)=Ok(25) + safeDiv(60,3)=Ok(20) + safeDiv(0-10,5)=Error(BadInput)->-5
// 25+20-5=40
Test EnxGMultipleResults {
    test {
        let v1 = enxGResultIntVal(enxGSafeDiv(100, 4))
        let v2 = enxGResultIntVal(enxGSafeDiv(60, 3))
        let v3 = enxGResultIntVal(enxGSafeDiv(0 - 10, 5))
        return v1 + v2 + v3
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(40); return e }
}

// Pipeline result feeding into rect creation
// pipeline(12,4,2,3)=2 -> makeRect(2,3)=Ok->area=6
Test EnxGPipelineFeedsRect {
    test {
        let w = enxGPipeline(12, 4, 2, 3)
        let r = enxGMakeRect(w, 3)
        var out = 0
        match r {
            Ok(rect) -> { out = rect.area() }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(6); return e }
}

// ---------------------------------------------------------------------------
// TRAP tests
// ---------------------------------------------------------------------------

// Direct divide by zero
Test EnxGTrapDivZero {
    test {
        let a = 42
        let b = 0
        return a / b
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// Direct mod by zero
Test EnxGTrapModZero {
    test {
        let a = 100
        let b = 0
        return a % b
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// Match Ok of range array, then index OOB
Test EnxGTrapOOBOnOkArray {
    test {
        let r = enxGBuildRange(3)
        var out = 0
        match r {
            Ok(xs) -> {
                let _ = xs[100]
                out = 0
            }
            Error(e) -> { out = enxGErrCode(e) }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// OOB on empty array
Test EnxGTrapOOBEmpty {
    test {
        let xs: [Int] = []
        let _ = xs[0]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// OOB on result array after building it
Test EnxGTrapResultArrayOOB {
    test {
        var results: [Result<Int, EnxGErr>] = []
        results.append(enxGSafeDiv(10, 2))
        results.append(enxGSafeDiv(20, 4))
        let _ = enxGResultIntVal(results[10])
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// Div by zero derived from rect area
// makeRect(3,0) -> Error, but if we coerce: use area as divisor from Ok
// makeRect(5,0) -> BadInput(-5), but 10 / (-5) is not zero...
// Instead: pipeline result that happens to be 0?
// Actually let's use: safeDiv(0,1)=Ok(0), then 5 / that value
Test EnxGTrapDivByOkValue {
    test {
        let r = enxGSafeDiv(0, 1)
        var divisor = 1
        match r {
            Ok(x)    -> { divisor = x }
            Error(e) -> { divisor = 1 }
        }
        return 5 / divisor
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// Mod by zero derived from Ok value
Test EnxGTrapModByOkValue {
    test {
        let r = enxGSafeDiv(0, 5)
        var d = 1
        match r {
            Ok(x)    -> { d = x }
            Error(e) -> { d = 1 }
        }
        return 42 % d
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// OOB via loop scanning result array past end
Test EnxGTrapResultArrayLoopOOB {
    test {
        var results: [Result<Int, EnxGErr>] = []
        var i = 0
        while i < 3 {
            results.append(enxGSafeDiv(i * 10, 2))
            i = i + 1
        }
        var acc = 0
        var j = 0
        while j < 10 {
            acc = acc + enxGResultIntVal(results[j])
            j = j + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}
