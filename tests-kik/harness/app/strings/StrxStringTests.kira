Test StrxPkLoop20 {
    test {
        var total = 0
        var i = 0
        while i < 20 {
            let s = strxPk(i)
            total = total + s.count
            i = i + 1
        }
        return total
    }
    // 4 periods of 15 = 60
    expect { let e: Result<Int, TestFailure> = Result.Ok(60); return e }
}

Test StrxPkLoop40 {
    test {
        var total = 0
        var i = 0
        while i < 40 {
            let s = strxPk(i)
            total = total + s.count
            i = i + 1
        }
        return total
    }
    // 8 periods of 15 = 120
    expect { let e: Result<Int, TestFailure> = Result.Ok(120); return e }
}

// Return a String from the test block directly
