Test StrxPkWrap {
    test {
        let s = strxPk(5)
        return s.count
    }
    // 5 % 5 = 0 -> "apple" = 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxPkBorBound {
    test {
        let s = strxPk(2)
        return strxBorLen(s)
    }
    // "three" = 5
