    test { return "hello" }
    expect { let e: Result<String, TestFailure> = Result.Ok("hello"); return e }
}

Test StrxRetPk0 {
    test {
        let s = strxPk(0)
        return s
    }
    expect { let e: Result<String, TestFailure> = Result.Ok("apple"); return e }
}

Test StrxRetPk3 {
    test {
        let s = strxPk(3)
        return s
    }
    expect { let e: Result<String, TestFailure> = Result.Ok("by"); return e }
}

// ---------------------------------------------------------------------------
// Struct with String field
// ---------------------------------------------------------------------------

Test StrxBoxNameLen {
    test {
        let b = StrxBox { name: "test", code: 0 }
        return b.name.count
    }
    // "test" = 4
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

Test StrxBoxMethod {
    test {
        let b = StrxBox { name: "hello", code: 0 }
        return b.nameLen()
    }
    // "hello" = 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxBoxCoded {
    test {
        let b = StrxBox { name: "", code: 99 }
        return b.coded()
    }
    // 99 + 1 = 100
    expect { let e: Result<Int, TestFailure> = Result.Ok(100); return e }
}

Test StrxBoxBorFn {
    test {
        let b = StrxBox { name: "abc", code: 7 }
        return strxBoxBor(b)
    }
    // 3 + 7 = 10
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test StrxBoxMutCode {
    test {
        var b = StrxBox { name: "x", code: 0 }
        var i = 0
        while i < 10 {
            b.code = b.code + 1
            i = i + 1
        }
        return b.code
    }
    // 10
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test StrxBoxNamePersist {
    test {
        var b = StrxBox { name: "hello", code: 0 }
        b.code = 999
        return b.name.count
    }
    // "hello" = 5 (name not changed)
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxBoxCopyIndep {
    test {
        let b = StrxBox { name: "abc", code: 5 }
        var c = b
        c.code = 99
        return b.code
    }
    // original unchanged = 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxBoxLoopBuild {
    test {
        var total = 0
        var i = 0
        while i < 5 {
            let nm = strxPk(i)
            let b = StrxBox { name: move nm, code: i }
            total = total + b.nameLen()
            i = i + 1
        }
        return total
    }
    // 1 period: 5+2+5+2+1 = 15
    expect { let e: Result<Int, TestFailure> = Result.Ok(15); return e }
}

Test StrxBoxLoopAcc {
    test {
        var acc = 0
        var i = 0
        while i < 8 {
            let nm = strxPk(i)
            let b = StrxBox { name: move nm, code: i }
            acc = acc + b.nameLen() + b.code
            i = i + 1
        }
        return acc
    }
    // i=0..7: nameLen=5,2,5,2,1,5,2,5 sum=27; code=0+1+2+3+4+5+6+7=28; total=55
    expect { let e: Result<Int, TestFailure> = Result.Ok(55); return e }
}

// ---------------------------------------------------------------------------
// Array of structs with String fields
// ---------------------------------------------------------------------------

Test StrxBoxArrCount {
    test {
        var boxes: [StrxBox] = []
        var i = 0
        while i < 8 {
            let nm = strxPk(i)
            boxes.append(StrxBox { name: move nm, code: i })
            i = i + 1
        }
        return boxes.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(8); return e }
}

Test StrxBoxArrSum {
    test {
        var boxes: [StrxBox] = []
        var i = 0
        while i < 10 {
            let nm = strxPk(i)
            boxes.append(StrxBox { name: move nm, code: 0 })
            i = i + 1
        }
        var total = 0
        var j = 0
        while j < boxes.count {
            total = total + boxes[j].nameLen()
            j = j + 1
        }
        return total
    }
    // 2 periods of 15 = 30
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test StrxBoxArrIdx3 {
    test {
        var boxes: [StrxBox] = []
        var i = 0
        while i < 10 {
            let nm = strxPk(i)
            boxes.append(StrxBox { name: move nm, code: i })
            i = i + 1
        }
        return boxes[3].name.count
    }
    // i=3 -> strxPk(3) = "by" = 2
    expect { let e: Result<Int, TestFailure> = Result.Ok(2); return e }
}

Test StrxBoxArrIdxCode {
    test {
        var boxes: [StrxBox] = []
        var i = 0
        while i < 6 {
            let nm = strxPk(i)
            boxes.append(StrxBox { name: move nm, code: i * 10 })
            i = i + 1
        }
        return boxes[4].code
    }
    // i=4 -> code = 40
    expect { let e: Result<Int, TestFailure> = Result.Ok(40); return e }
}

// ---------------------------------------------------------------------------
// Nested struct with String field
// ---------------------------------------------------------------------------

Test StrxOutLen1 {
    test {
        let o = StrxBoxOuter {
            inner: StrxBoxInner { word: "hello" },
            tag: "ab",
            n: 10
        }
        return strxOutLen(o)
    }
    // 5 + 2 + 10 = 17
    expect { let e: Result<Int, TestFailure> = Result.Ok(17); return e }
}

Test StrxOutLen2 {
    test {
        let o = StrxBoxOuter {
            inner: StrxBoxInner { word: "" },
            tag: "xyz",
            n: 0
        }
        return strxOutLen(o)
    }
    // 0 + 3 + 0 = 3
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test StrxOutDirect {
    test {
        let o = StrxBoxOuter {
            inner: StrxBoxInner { word: "abcd" },
            tag: "xy",
            n: 5
        }
        return o.inner.word.count
    }
    // "abcd" = 4
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

Test StrxOutTagCount {
    test {
        let o = StrxBoxOuter {
            inner: StrxBoxInner { word: "test" },
            tag: "kira",
            n: 0
        }
        return o.tag.count
    }
    // "kira" = 4
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

Test StrxOutTwoFields {
    test {
        let o = StrxBoxOuter {
            inner: StrxBoxInner { word: "abcde" },
            tag: "xy",
            n: 3
        }
        return o.inner.word.count + o.tag.count
    }
    // 5 + 2 = 7
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

Test StrxInnerWordLen {
    test {
        let inn = StrxBoxInner { word: "hello" }
        return inn.word.count
    }
    // 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

