// StrxStringTests.kira — deep string coverage for `kira test`.
// PREFIX: strx / Strx  (all top-level names use this prefix).
// No `import Foundation` — harness flat namespace already has it.

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

function strxBorLen(s: borrow String) -> Int {
    return s.count
}

function strxMvLen(s: String) -> Int {
    return s.count
}

// Returns one of 5 strings by i%5.
// Period: "apple"(5) "go"(2) "three"(5) "by"(2) "x"(1) → sum per period = 15
function strxPk(i: Int) -> String {
    let m = i % 5
    if m == 0 { return "apple" }
    if m == 1 { return "go" }
    if m == 2 { return "three" }
    if m == 3 { return "by" }
    return "x"
}

// ---------------------------------------------------------------------------
// Structs
// ---------------------------------------------------------------------------

struct StrxBox {
    var name: String
    var code: Int

    function nameLen() -> Int {
        return self.name.count
    }

    function coded() -> Int {
        return self.code + 1
    }
}

function strxBoxBor(b: borrow StrxBox) -> Int {
    return b.name.count + b.code
}

struct StrxBoxInner {
    var word: String
}

struct StrxBoxOuter {
    var inner: StrxBoxInner
    var tag: String
    var n: Int
}

function strxOutLen(o: borrow StrxBoxOuter) -> Int {
    return o.inner.word.count + o.tag.count + o.n
}

// ---------------------------------------------------------------------------
// Enum with String payload
// ---------------------------------------------------------------------------

enum StrxLbl {
    Named(String)
    Empty
}

function strxLblLen(l: borrow StrxLbl) -> Int {
    match l {
        Named(s) -> { return s.count }
        Empty -> { return 0 }
    }
}

// Period of 3: Named("hello")(5), Empty(0), Named("ok")(2) → sum = 7
function strxLblFor(i: Int) -> StrxLbl {
    let m = i % 3
    if m == 0 { return StrxLbl.Named("hello") }
    if m == 1 { return StrxLbl.Empty }
    return StrxLbl.Named("ok")
}

// ---------------------------------------------------------------------------
// Literal .count tests
// ---------------------------------------------------------------------------

Test StrxLitA {
    test { return "a".count }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

Test StrxLitHello {
    test { return "hello".count }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxLitEmpty {
    test { return "".count }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test StrxLitTen {
    test { return "abcdefghij".count }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test StrxLitKira {
    test { return "kira".count }
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

Test StrxLitSpace {
    test { return "hello world".count }
    expect { let e: Result<Int, TestFailure> = Result.Ok(11); return e }
}

Test StrxLitTwelve {
    test { return "123456789012".count }
    expect { let e: Result<Int, TestFailure> = Result.Ok(12); return e }
}

// ---------------------------------------------------------------------------
// Borrow-len helper tests
// ---------------------------------------------------------------------------

Test StrxBorLitXyz {
    test { return strxBorLen("xyz") }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test StrxBorLitEmpty {
    test { return strxBorLen("") }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test StrxBorVar {
    test {
        let s = "reuse"
        return strxBorLen(s)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxBorVarTwice {
    test {
        let s = "ab"
        var out = strxBorLen(s)
        out = out + strxBorLen(s)
        return out
    }
    // 2 + 2 = 4
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

Test StrxBorSix {
    test { return strxBorLen("abcdef") }
    expect { let e: Result<Int, TestFailure> = Result.Ok(6); return e }
}

Test StrxBorMixed {
    test {
        var out = strxBorLen("xy")
        out = out + strxBorLen("abc")
        return out
    }
    // 2 + 3 = 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

// ---------------------------------------------------------------------------
// Move-len helper tests
// ---------------------------------------------------------------------------

Test StrxMvLit {
    test { return strxMvLen(move "consume") }
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

Test StrxMvVar {
    test {
        let s = "transfer"
        return strxMvLen(move s)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(8); return e }
}

// ---------------------------------------------------------------------------
// String-returning function tests (bind result before .count)
// ---------------------------------------------------------------------------

Test StrxPkApple {
    test {
        let s = strxPk(0)
        return s.count
    }
    // "apple" = 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxPkGo {
    test {
        let s = strxPk(1)
        return s.count
    }
    // "go" = 2
    expect { let e: Result<Int, TestFailure> = Result.Ok(2); return e }
}

Test StrxPkThreeStr {
    test {
        let s = strxPk(2)
        return s.count
    }
    // "three" = 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxPkBy {
