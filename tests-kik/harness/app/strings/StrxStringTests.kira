        return strxLblLen(l)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test StrxLblNamedZero {
    test {
        let l = StrxLbl.Named("")
        return strxLblLen(l)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test StrxLblFor0 {
    test {
        let l = strxLblFor(0)
        return strxLblLen(l)
    }
    // Named("hello") = 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxLblFor1 {
    test {
        let l = strxLblFor(1)
        return strxLblLen(l)
    }
    // Empty = 0
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test StrxLblFor2 {
    test {
        let l = strxLblFor(2)
        return strxLblLen(l)
    }
    // Named("ok") = 2
    expect { let e: Result<Int, TestFailure> = Result.Ok(2); return e }
}

Test StrxLblFor3 {
    test {
        let l = strxLblFor(3)
        return strxLblLen(l)
    }
    // 3 % 3 = 0 -> Named("hello") = 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxLblLoopSum {
    test {
        var total = 0
        var i = 0
        while i < 30 {
            let l = strxLblFor(i)
            total = total + strxLblLen(l)
            i = i + 1
        }
        return total
    }
    // 10 periods of (5+0+2) = 70
    expect { let e: Result<Int, TestFailure> = Result.Ok(70); return e }
}

Test StrxLblArrBuild {
    test {
        var lbls: [StrxLbl] = []
        var i = 0
        while i < 15 {
            lbls.append(strxLblFor(i))
            i = i + 1
        }
        var total = 0
        var j = 0
        while j < lbls.count {
            total = total + strxLblLen(lbls[j])
            j = j + 1
        }
        return total
    }
    // 5 periods of 7 = 35
    expect { let e: Result<Int, TestFailure> = Result.Ok(35); return e }
}

Test StrxLblArrCount {
    test {
        var lbls: [StrxLbl] = []
        var i = 0
        while i < 9 {
            lbls.append(strxLblFor(i))
            i = i + 1
        }
        return lbls.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(9); return e }
}

// ---------------------------------------------------------------------------
// String arrays — literal and built
// ---------------------------------------------------------------------------

Test StrxArrLitIdx0 {
    test {
        let arr = ["one", "two", "three"]
        return arr[0].count
    }
    // "one" = 3
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test StrxArrLitIdx2 {
    test {
        let arr = ["one", "two", "three"]
        return arr[2].count
    }
    // "three" = 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxArrLitForIn {
    test {
        let ws = ["cat", "dog", "fish", ""]
        var total = 0
        for w in ws {
            total = total + w.count
        }
        return total
    }
    // 3+3+4+0 = 10
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test StrxArrLitCount {
    test {
        let arr = ["a", "b", "c"]
        return arr.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test StrxArrBuildCount {
    test {
        var arr: [String] = []
        var i = 0
        while i < 10 {
            let s = strxPk(i)
            arr.append(move s)
            i = i + 1
        }
        return arr.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test StrxArrBuildSum {
    test {
        var arr: [String] = []
        var i = 0
        while i < 15 {
            let s = strxPk(i)
            arr.append(move s)
            i = i + 1
        }
        var total = 0
        var j = 0
        while j < arr.count {
            total = total + arr[j].count
            j = j + 1
        }
        return total
    }
    // 3 periods of 15 = 45
    expect { let e: Result<Int, TestFailure> = Result.Ok(45); return e }
}

Test StrxArrBuildIdx {
    test {
        var arr: [String] = []
        var i = 0
        while i < 5 {
            let s = strxPk(i)
            arr.append(move s)
            i = i + 1
        }
        return arr[2].count
    }
    // strxPk(2) = "three" = 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxArrBuildMvLen {
    test {
        var arr: [String] = []
        var buildTotal = 0
        var i = 0
        while i < 20 {
            let s = strxPk(i)
            buildTotal = buildTotal + s.count
            arr.append(move s)
            i = i + 1
        }
        // Also sum by index access
        var indexTotal = 0
        var j = 0
        while j < arr.count {
            indexTotal = indexTotal + arr[j].count
            j = j + 1
        }
        // Both should be equal; return their sum
        return buildTotal + indexTotal
    }
    // 4 periods of 15 = 60 each -> 120
    expect { let e: Result<Int, TestFailure> = Result.Ok(120); return e }
}

// ---------------------------------------------------------------------------
// Per-iteration string selection by index
// ---------------------------------------------------------------------------

Test StrxSelByMod {
    test {
        var total = 0
        var i = 0
        while i < 10 {
            var cnt = 0
            if i % 2 == 0 {
                cnt = "cat".count
            } else {
                cnt = "dog".count
            }
            total = total + cnt
            i = i + 1
        }
        return total
    }
    // 5*3 + 5*3 = 30
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test StrxCountUnderThree {
    test {
        var cnt = 0
        var i = 0
        while i < 20 {
            let s = strxPk(i)
            if s.count < 3 {
                cnt = cnt + 1
            }
            i = i + 1
        }
        return cnt
    }
    // per period of 5: "go"(2)<3 yes, "by"(2)<3 yes, "x"(1)<3 yes -> 3 per period
    // 4 periods -> 12
    expect { let e: Result<Int, TestFailure> = Result.Ok(12); return e }
}

// ---------------------------------------------------------------------------
// Trap tests
// ---------------------------------------------------------------------------

Test StrxTrapArrOob {
    test {
        let arr: [String] = ["a", "b"]
        let s = arr[5]
        return s.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxTrapBoxArrOob {
    test {
        var boxes: [StrxBox] = []
        boxes.append(StrxBox { name: "x", code: 1 })
        let _ = boxes[5].code
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxTrapLblArrOob {
    test {
        var lbls: [StrxLbl] = []
        lbls.append(StrxLbl.Empty)
        let _ = strxLblLen(lbls[3])
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxTrapDivZero {
    test {
        let a = 5
        let b = 0
        return a / b
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxTrapModZero {
    test {
        let a = 10
        let b = 0
        return a % b
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxTrapStrArrEmpty {
    test {
        let arr: [String] = []
        let s = arr[0]
        return s.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}
