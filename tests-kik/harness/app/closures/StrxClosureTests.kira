// ---------------------------------------------------------------------------
// Higher-order: apply, applyTwice, applyN
// ---------------------------------------------------------------------------

Test StrxClApplyTwiceInc {
    test {
        let inc: (Int) -> Int = { x in return x + 1 }
        return strxCApplyTwice(move inc, 10)
    }
    // 10+1+1 = 12
    expect { let e: Result<Int, TestFailure> = Result.Ok(12); return e }
}

Test StrxClApplyTwiceSq {
    test {
        let sq: (Int) -> Int = { x in return x * x }
        return strxCApplyTwice(move sq, 3)
    }
    // sq(sq(3)) = sq(9) = 81
    expect { let e: Result<Int, TestFailure> = Result.Ok(81); return e }
}

Test StrxClApplyTwiceDbl {
    test {
        let dbl: (Int) -> Int = { x in return x * 2 }
        return strxCApplyTwice(move dbl, 5)
    }
    // 5*2*2 = 20
    expect { let e: Result<Int, TestFailure> = Result.Ok(20); return e }
}

Test StrxClApplyN5 {
    test {
        let dbl: (Int) -> Int = { x in return x * 2 }
        return strxCApplyN(move dbl, 1, 5)
    }
    // 2^5 = 32
    expect { let e: Result<Int, TestFailure> = Result.Ok(32); return e }
}

Test StrxClApplyN0 {
    test {
        let inc: (Int) -> Int = { x in return x + 1 }
        return strxCApplyN(move inc, 5, 0)
    }
    // 0 applications -> 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxClApplyNInc10 {
    test {
        let inc: (Int) -> Int = { x in return x + 1 }
        return strxCApplyN(move inc, 100, 50)
    }
    // 100 + 50 = 150
    expect { let e: Result<Int, TestFailure> = Result.Ok(150); return e }
}

