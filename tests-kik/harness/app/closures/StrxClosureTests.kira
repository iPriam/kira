// StrxClosureTests.kira — deep closure coverage for `kira test`.
// PREFIX: strx / Strx  (all top-level names use this prefix).
// No `import Foundation` — already in scope.

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

function strxCAdd(a: Int, b: Int) -> Int {
    return a + b
}

function strxCMul(a: Int, b: Int) -> Int {
    return a * b
}

function strxCSub(a: Int, b: Int) -> Int {
    return a - b
}

function strxCApply(f: (Int) -> Int, x: Int) -> Int {
    return f(x)
}

function strxCApplyTwice(f: (Int) -> Int, x: Int) -> Int {
    return f(f(x))
}

function strxCApplyN(f: (Int) -> Int, x: Int, n: Int) -> Int {
    var res = x
    var i = 0
    while i < n {
        res = f(res)
        i = i + 1
    }
    return res
}

function strxCReduce(xs: borrow [Int], f: (Int) -> Int) -> Int {
    var total = 0
    var i = 0
    while i < xs.count {
        total = total + f(xs[i])
        i = i + 1
    }
    return total
}

function strxCFold(xs: borrow [Int], f: (Int, Int) -> Int, init: Int) -> Int {
    var acc = init
    var i = 0
    while i < xs.count {
        acc = f(acc, xs[i])
        i = i + 1
    }
    return acc
}

// ---------------------------------------------------------------------------
// Named function references passed as values
// ---------------------------------------------------------------------------

Test StrxClNamedAdd {
    test {
        let f: (Int, Int) -> Int = strxCAdd
        return f(10, 32)
    }
    // 42
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

Test StrxClNamedMul {
    test {
        let f: (Int, Int) -> Int = strxCMul
        return f(6, 7)
    }
    // 42
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

Test StrxClNamedSub {
    test {
        let f: (Int, Int) -> Int = strxCSub
        return f(50, 8)
    }
    // 42
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

Test StrxClNamedToApply {
    test {
        let inc: (Int) -> Int = { x in return x + 1 }
        return strxCApply(move inc, 41)
    }
    // 42
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

