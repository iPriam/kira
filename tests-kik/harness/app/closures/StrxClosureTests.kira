// ---------------------------------------------------------------------------
// Immutable by-value captures
// ---------------------------------------------------------------------------

Test StrxClCapImm1 {
    test {
        let base = 100
        let f: (Int) -> Int = { x in return x + base }
        return f(42)
    }
    // 142
    expect { let e: Result<Int, TestFailure> = Result.Ok(142); return e }
}

Test StrxClCapImm2 {
    test {
        let mult = 7
        let f: (Int) -> Int = { x in return x * mult }
        return f(6)
    }
    // 42
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

Test StrxClCapImmLoop {
    test {
        let base = 1000
        let f: (Int) -> Int = { x in return x + base }
        var acc = 0
        var i = 0
        while i < 10 {
            acc = acc + f(i)
            i = i + 1
        }
        return acc
    }
    // sum(i+1000 for i in 0..9) = 45 + 10000 = 10045
    expect { let e: Result<Int, TestFailure> = Result.Ok(10045); return e }
}

Test StrxClCapImmPow2 {
    test {
        let factor = 2
        let xs = [1, 2, 3, 4, 5]
        let f: (Int) -> Int = { x in return x * factor }
        return strxCReduce(xs, move f)
    }
    // 2+4+6+8+10 = 30
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test StrxClCapImmSub {
    test {
        let offset = 5
        let f: (Int) -> Int = { x in return x - offset }
        return f(12)
    }
    // 7
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

Test StrxClCapImmMul3 {
    test {
        let factor = 3
        let f: (Int) -> Int = { x in return x * factor }
        var acc = 0
        var i = 1
        while i <= 6 {
            acc = acc + f(i)
            i = i + 1
        }
        return acc
    }
    // 3*(1+2+3+4+5+6) = 63
    expect { let e: Result<Int, TestFailure> = Result.Ok(63); return e }
}

Test StrxClCapImmTop {
    test {
        let top = 100
        let f: (Int) -> Int = { x in return top - x }
        var acc = 0
        var i = 0
        while i < 5 {
            acc = acc + f(i)
            i = i + 1
        }
        return acc
    }
    // (100+99+98+97+96) = 490
    expect { let e: Result<Int, TestFailure> = Result.Ok(490); return e }
}

Test StrxClCapImmDiv {
    test {
        let divisor = 4
        let f: (Int) -> Int = { x in return x / divisor }
        var acc = 0
        var i = 0
        while i < 8 {
            acc = acc + f(i * 4)
            i = i + 1
        }
        return acc
    }
    // i*4/4 = i; sum(0..7) = 28
    expect { let e: Result<Int, TestFailure> = Result.Ok(28); return e }
}

// ---------------------------------------------------------------------------
// Shared mutable var captures
// ---------------------------------------------------------------------------

Test StrxClMutTotal {
    test {
        var total = 0
        let acc: (Int) -> Int = { x in
            total = total + x
            return total
        }
        var i = 1
        while i <= 10 {
            let _ = acc(i)
            i = i + 1
        }
        return total
    }
    // 1+2+...+10 = 55
    expect { let e: Result<Int, TestFailure> = Result.Ok(55); return e }
}

Test StrxClMutCount {
    test {
        var count = 0
        let tick: (Int) -> Int = { x in
            count = count + 1
            return count
        }
        var i = 0
        while i < 5 {
            let _ = tick(0)
            i = i + 1
        }
        return count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxClMutMul {
    test {
        var prod = 1
        let mul: (Int) -> Int = { x in
            prod = prod * x
            return prod
        }
        var i = 1
        while i <= 5 {
            let _ = mul(i)
            i = i + 1
        }
        return prod
    }
    // 1*2*3*4*5 = 120
    expect { let e: Result<Int, TestFailure> = Result.Ok(120); return e }
}

Test StrxClMutToggle {
    test {
        var flag = 0
        let toggle: (Int) -> Int = { x in
            if flag == 0 {
                flag = 1
            } else {
                flag = 0
            }
            return flag
        }
        var i = 0
        while i < 6 {
            let _ = toggle(0)
            i = i + 1
        }
        return flag
    }
    // 6 toggles from 0 -> 1,0,1,0,1,0 = 0
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test StrxClMutEvenCount {
    test {
        var evens = 0
        let countEven: (Int) -> Int = { x in
            if x % 2 == 0 {
                evens = evens + 1
            }
            return evens
        }
        var i = 0
        while i < 10 {
            let _ = countEven(i)
            i = i + 1
        }
        return evens
    }
    // 0,2,4,6,8 -> 5 evens
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxClMutAccumProd {
    test {
        let mult = 3
        var total = 0
        let addMult: (Int) -> Int = { x in
            total = total + x * mult
            return total
        }
        var i = 1
        while i <= 5 {
            let _ = addMult(i)
            i = i + 1
        }
        return total
    }
    // 3*(1+2+3+4+5) = 45
    expect { let e: Result<Int, TestFailure> = Result.Ok(45); return e }
}

Test StrxClMutBucket {
    test {
        var bucket = 0
        let deposit: (Int) -> Int = { x in
            bucket = bucket + x * 2
            return bucket
        }
        var i = 1
        while i <= 5 {
            let _ = deposit(i)
            i = i + 1
        }
        return bucket
    }
    // 2*(1+2+3+4+5) = 30
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test StrxClMutMax {
    test {
        var mx = 0
        let track: (Int) -> Int = { x in
            if x > mx {
                mx = x
            }
            return mx
        }
        let vals = [3, 7, 2, 9, 1, 5]
        var i = 0
        while i < vals.count {
            let _ = track(vals[i])
            i = i + 1
        }
        return mx
    }
    // max is 9
    expect { let e: Result<Int, TestFailure> = Result.Ok(9); return e }
}

Test StrxClMutCountDown {
    test {
        var remaining = 10
        let use: (Int) -> Int = { x in
            remaining = remaining - 1
            return remaining
        }
        var i = 0
        while i < 7 {
            let _ = use(0)
            i = i + 1
        }
        return remaining
    }
    // 10 - 7 = 3
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test StrxClMutRunning {
    test {
        var running = 0
        let update: (Int) -> Int = { x in
            running = running + x
            return running
        }
        let vals = [2, 4, 6, 8]
        var i = 0
        while i < vals.count {
            let _ = update(vals[i])
            i = i + 1
        }
        return running
    }
    // 2+4+6+8 = 20
    expect { let e: Result<Int, TestFailure> = Result.Ok(20); return e }
}

Test StrxClMutTriangle {
    test {
        var sum = 0
        let addI: (Int) -> Int = { x in
            sum = sum + x
            return sum
        }
        var i = 1
        while i <= 10 {
            let _ = addI(i)
            i = i + 1
        }
        return sum
    }
    // 1+2+...+10 = 55
    expect { let e: Result<Int, TestFailure> = Result.Ok(55); return e }
}

Test StrxClMutLoopModify {
    test {
        var accum = 0
        let add: (Int) -> Int = { x in
            accum = accum + x
            return x
        }
        var i = 0
        while i < 8 {
            let _ = add(i * 3)
            i = i + 1
        }
        return accum
    }
    // 0+3+6+9+12+15+18+21 = 84
    expect { let e: Result<Int, TestFailure> = Result.Ok(84); return e }
}

// ---------------------------------------------------------------------------
// Compose by sequencing (two closures, one after another)
// ---------------------------------------------------------------------------

Test StrxClCompose {
    test {
        let f: (Int) -> Int = { x in return x + 3 }
        let g: (Int) -> Int = { x in return x * 2 }
        let r1 = strxCApply(move f, 5)
        let r2 = strxCApply(move g, r1)
        return r2
    }
    // (5+3)*2 = 16
    expect { let e: Result<Int, TestFailure> = Result.Ok(16); return e }
}

Test StrxClComposeLoop {
    test {
        var acc = 0
        var i = 0
        while i < 5 {
            let f: (Int) -> Int = { x in return x + i }
            let g: (Int) -> Int = { x in return x * 2 }
            let mid = strxCApply(move f, i)
            acc = acc + strxCApply(move g, mid)
            i = i + 1
        }
        return acc
    }
    // i=0: (0+0)*2=0; i=1: (1+1)*2=4; i=2: (2+2)*2=8; i=3: (3+3)*2=12; i=4: (4+4)*2=16
    // sum = 40
    expect { let e: Result<Int, TestFailure> = Result.Ok(40); return e }
}

Test StrxClNestedHOF {
    test {
        let xs = [1, 2, 3, 4]
        let add2: (Int) -> Int = { x in return x + 2 }
        let r1 = strxCReduce(xs, move add2)
        let dbl: (Int) -> Int = { x in return x * 2 }
        return strxCApply(move dbl, r1)
    }
    // reduce: 3+4+5+6=18; apply dbl: 36
    expect { let e: Result<Int, TestFailure> = Result.Ok(36); return e }
}

// ---------------------------------------------------------------------------
// More patterns
// ---------------------------------------------------------------------------

Test StrxClSingleCall {
    test {
        let add1: (Int) -> Int = { x in return x + 1 }
        let r = strxCApplyTwice(move add1, 40)
        return r
    }
    // 40+1+1 = 42
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

Test StrxClDirectCall {
    test {
        let f: (Int) -> Int = { x in return x * x }
        return f(9)
    }
    // 81
    expect { let e: Result<Int, TestFailure> = Result.Ok(81); return e }
}

Test StrxClMultiCallSameClosure {
    test {
        let f: (Int) -> Int = { x in return x + 5 }
        var acc = 0
        acc = acc + f(0)
        acc = acc + f(10)
        acc = acc + f(20)
        return acc
    }
    // 5+15+25 = 45
    expect { let e: Result<Int, TestFailure> = Result.Ok(45); return e }
}

Test StrxClChainResult {
    test {
        var step = 1
        let f: (Int) -> Int = { x in return x + step }
        var out = 0
        var i = 0
        while i < 5 {
            out = f(out)
            i = i + 1
        }
        return out
    }
    // starts 0, adds step=1 five times -> 5
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StrxClReduceThenApply {
    test {
        let xs = [2, 4, 6]
        let id: (Int) -> Int = { x in return x }
        let sum = strxCReduce(xs, move id)
        let triple: (Int) -> Int = { x in return x * 3 }
        return strxCApply(move triple, sum)
    }
    // sum=12; 12*3=36
    expect { let e: Result<Int, TestFailure> = Result.Ok(36); return e }
}

// ---------------------------------------------------------------------------
// Trap tests — closure body traps, or outer array OOB
// ---------------------------------------------------------------------------

Test StrxClTrapOobInClosure {
    test {
        // Closure body itself causes OOB by computing an out-of-range index
        let f: (Int) -> Int = { x in
            let dummy = [1, 2, 3]
            return dummy[x]
        }
        return f(99)
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxClTrapDivZeroInClosure {
    test {
        let f: (Int) -> Int = { x in return 100 / x }
        return f(0)
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxClTrapModZeroInClosure {
    test {
        let f: (Int) -> Int = { x in return x % 0 }
        return f(5)
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxClTrapOobDirect {
    test {
        let xs: [Int] = [1, 2, 3]
        let _ = xs[10]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxClTrapOobBeforeApply {
    test {
        let f: (Int) -> Int = { x in return x * 2 }
        let xs = [1, 2, 3]
        return strxCApply(move f, xs[99])
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}
