Test StrxClInlineTernary {
    test {
        let f: (Int) -> Int = { x in return x > 5 ? 100 : 0 }
        return f(7)
    }
    // 100
    expect { let e: Result<Int, TestFailure> = Result.Ok(100); return e }
}

Test StrxClInlineTernaryFalse {
    test {
        let f: (Int) -> Int = { x in return x > 5 ? 100 : 0 }
        return f(3)
