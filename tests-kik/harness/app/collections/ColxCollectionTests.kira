Test ColxSumLiteral {
    test {
        var xs: [Int] = []
        xs.append(1)
        xs.append(2)
        xs.append(3)
        xs.append(4)
        xs.append(5)
        return colxSum(xs)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(15); return e }
}

Test ColxSumRange10 {
    test {
        let xs = colxBuildRange(10)
        return colxSum(xs)
    }
    // 0+1+...+9 = 45
    expect { let e: Result<Int, TestFailure> = Result.Ok(45); return e }
}

Test ColxSumSquares5 {
    test {
        let xs = colxBuildSquares(5)
        return colxSum(xs)
    }
    // 0+1+4+9+16 = 30
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test ColxSumSquares10 {
    test {
        let xs = colxBuildSquares(10)
        return colxSum(xs)
    }
    // 0+1+4+9+16+25+36+49+64+81 = 285
    expect { let e: Result<Int, TestFailure> = Result.Ok(285); return e }
}

Test ColxSumFib8 {
    test {
        let xs = colxBuildFib(8)
        return colxSum(xs)
    }
    // [0,1,1,2,3,5,8,13] -> 33
    expect { let e: Result<Int, TestFailure> = Result.Ok(33); return e }
}

Test ColxForInSumLiteral {
    test {
        var acc = 0
        for v in [10, 20, 30, 40, 50] {
            acc = acc + v
        }
        return acc
    }
    // 10+20+30+40+50 = 150
    expect { let e: Result<Int, TestFailure> = Result.Ok(150); return e }
}

Test ColxForInProductLiteral {
    test {
        var p = 1
        for v in [1, 2, 3, 4, 5] {
            p = p * v
        }
        return p
    }
    // 1*2*3*4*5 = 120
    expect { let e: Result<Int, TestFailure> = Result.Ok(120); return e }
}

Test ColxForInCountGt4 {
    test {
        var c = 0
        for v in [3, 1, 4, 1, 5, 9, 2, 6, 5, 3] {
            if v > 4 {
                c = c + 1
            }
        }
        return c
    }
    // elements >4: 5,9,6,5 => 4
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

Test ColxForInMax {
    test {
        var m = 0
        for v in [3, 1, 4, 1, 5, 9, 2, 6, 5, 3] {
            if v > m {
                m = v
            }
        }
        return m
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(9); return e }
}

Test ColxForInSquaresSum {
    test {
        var acc = 0
        for v in [1, 2, 3, 4, 5] {
            acc = acc + v * v
        }
        return acc
    }
    // 1+4+9+16+25 = 55
    expect { let e: Result<Int, TestFailure> = Result.Ok(55); return e }
}

