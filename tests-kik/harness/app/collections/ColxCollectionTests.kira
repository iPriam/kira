// ColxCollectionTests.kira
// Deep array test suite. All top-level names use colx / Colx prefix.
// ~85 tests (including ~20 trap tests).

// ---------------------------------------------------------------------------
// Struct types
// ---------------------------------------------------------------------------

struct ColxPt {
    var x: Int
    var y: Int
}

struct ColxBox {
    var lo: Int
    var hi: Int

    function size() -> Int {
        return self.hi - self.lo
    }

    function mid() -> Int {
        return (self.lo + self.hi) / 2
    }
}

struct ColxGrid {
    var cells: [Int]

    function sum() -> Int {
        var t = 0
        var i = 0
        while i < self.cells.count {
            t = t + self.cells[i]
            i = i + 1
        }
        return t
    }

    function cellCount() -> Int {
        return self.cells.count
    }
}

// ---------------------------------------------------------------------------
// Helper functions
// ---------------------------------------------------------------------------

function colxSum(xs: borrow [Int]) -> Int {
    var total = 0
    var i = 0
    while i < xs.count {
        total = total + xs[i]
        i = i + 1
    }
    return total
}

function colxMin(xs: borrow [Int]) -> Int {
    var m = xs[0]
    var i = 1
    while i < xs.count {
        if xs[i] < m {
            m = xs[i]
        }
        i = i + 1
    }
    return m
}

function colxMax(xs: borrow [Int]) -> Int {
    var m = xs[0]
    var i = 1
    while i < xs.count {
        if xs[i] > m {
            m = xs[i]
        }
        i = i + 1
    }
    return m
}

function colxContainsVal(xs: borrow [Int], val: Int) -> Bool {
    var i = 0
    while i < xs.count {
        if xs[i] == val {
            return true
        }
        i = i + 1
    }
    return false
}

function colxBuildRange(n: Int) -> [Int] {
    var xs: [Int] = []
    var i = 0
    while i < n {
        xs.append(i)
        i = i + 1
    }
    return xs
}

function colxBuildSquares(n: Int) -> [Int] {
    var xs: [Int] = []
    var i = 0
    while i < n {
        xs.append(i * i)
        i = i + 1
    }
    return xs
}

function colxBuildFib(n: Int) -> [Int] {
    var xs: [Int] = []
    if n == 0 {
        return xs
    }
    xs.append(0)
    if n == 1 {
        return xs
    }
    xs.append(1)
    var i = 2
    while i < n {
        let p1 = xs[i - 1]
        let p2 = xs[i - 2]
        xs.append(p1 + p2)
        i = i + 1
    }
    return xs
}

function colxReverse(xs: borrow [Int]) -> [Int] {
    var out: [Int] = []
    var i = xs.count
    while i > 0 {
        i = i - 1
        out.append(xs[i])
    }
    return out
}

function colxCountGt(xs: borrow [Int], thresh: Int) -> Int {
    var c = 0
    var i = 0
    while i < xs.count {
        if xs[i] > thresh {
            c = c + 1
        }
        i = i + 1
    }
    return c
}

function colxProduct(xs: borrow [Int]) -> Int {
    var p = 1
    var i = 0
    while i < xs.count {
        p = p * xs[i]
        i = i + 1
    }
    return p
}

// ---------------------------------------------------------------------------
// GROUP A - Empty / count
// ---------------------------------------------------------------------------

Test ColxEmptyCount {
    test {
        let xs: [Int] = []
        return xs.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test ColxOneAppendCount {
    test {
        var xs: [Int] = []
        xs.append(42)
        return xs.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

Test ColxFiveAppendCount {
    test {
        var xs: [Int] = []
        xs.append(1)
        xs.append(2)
        xs.append(3)
        xs.append(4)
        xs.append(5)
        return xs.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test ColxTrapEmptyIdx0 {
    test {
        var xs: [Int] = []
        let _ = xs[0]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test ColxTrapEmptyIdx99 {
    test {
        var xs: [Int] = []
        let _ = xs[99]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

