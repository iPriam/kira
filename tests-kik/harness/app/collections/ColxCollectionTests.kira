// ---------------------------------------------------------------------------
// GROUP H - Arrays of structs
// ---------------------------------------------------------------------------

Test ColxPtArrayCount {
    test {
        var pts: [ColxPt] = []
        var i = 0
        while i < 5 {
            pts.append(ColxPt { x: i, y: i * 2 })
            i = i + 1
        }
        return pts.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test ColxPtSumX {
    test {
        var pts: [ColxPt] = []
        var i = 0
        while i < 5 {
            pts.append(ColxPt { x: i, y: i * 2 })
            i = i + 1
        }
        var s = 0
        var j = 0
        while j < pts.count {
            s = s + pts[j].x
            j = j + 1
        }
        return s
    }
    // x=0+1+2+3+4 = 10
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test ColxPtSumY {
    test {
        var pts: [ColxPt] = []
        var i = 0
        while i < 5 {
            pts.append(ColxPt { x: i, y: i * 2 })
            i = i + 1
        }
        var s = 0
        var j = 0
        while j < pts.count {
            s = s + pts[j].y
            j = j + 1
        }
        return s
    }
    // y=0+2+4+6+8 = 20
    expect { let e: Result<Int, TestFailure> = Result.Ok(20); return e }
}

Test ColxPtSumBoth {
    test {
        var pts: [ColxPt] = []
        var i = 0
        while i < 5 {
            pts.append(ColxPt { x: i, y: i + 1 })
            i = i + 1
        }
        var s = 0
        var j = 0
        while j < pts.count {
            s = s + pts[j].x + pts[j].y
            j = j + 1
        }
        return s
    }
    // x: 0+1+2+3+4=10, y: 1+2+3+4+5=15, total=25
    expect { let e: Result<Int, TestFailure> = Result.Ok(25); return e }
}

Test ColxPtMutateByIndex {
    test {
        var pts: [ColxPt] = []
        pts.append(ColxPt { x: 1, y: 1 })
        pts.append(ColxPt { x: 2, y: 2 })
        pts.append(ColxPt { x: 3, y: 3 })
        var local = pts[1]
        local.x = 100
        local.y = 200
        pts[1] = local
        return pts[1].x + pts[1].y
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(300); return e }
}

Test ColxPtBuildLarge {
    test {
        var pts: [ColxPt] = []
        var i = 0
        while i < 20 {
            pts.append(ColxPt { x: i, y: i + 1 })
            i = i + 1
        }
        var s = 0
        var j = 0
        while j < pts.count {
            s = s + pts[j].x + pts[j].y
            j = j + 1
        }
        return s
    }
    // sum x=0+1+...+19=190, sum y=1+2+...+20=210, total=400
    expect { let e: Result<Int, TestFailure> = Result.Ok(400); return e }
}

Test ColxBoxSumSizes {
    test {
        var boxes: [ColxBox] = []
        boxes.append(ColxBox { lo: 0, hi: 10 })
        boxes.append(ColxBox { lo: 5, hi: 15 })
        boxes.append(ColxBox { lo: 2, hi: 8 })
        var s = 0
        var i = 0
        while i < boxes.count {
            s = s + boxes[i].size()
            i = i + 1
        }
        return s
    }
    // sizes: 10+10+6 = 26
    expect { let e: Result<Int, TestFailure> = Result.Ok(26); return e }
}

Test ColxBoxSumMids {
    test {
        var boxes: [ColxBox] = []
        boxes.append(ColxBox { lo: 0, hi: 10 })
        boxes.append(ColxBox { lo: 4, hi: 12 })
        boxes.append(ColxBox { lo: 6, hi: 20 })
        var s = 0
        var i = 0
        while i < boxes.count {
            s = s + boxes[i].mid()
            i = i + 1
        }
        return s
    }
    // mids: (0+10)/2=5, (4+12)/2=8, (6+20)/2=13 -> 26
    expect { let e: Result<Int, TestFailure> = Result.Ok(26); return e }
}

Test ColxPtWritebackLoop {
    test {
        var pts: [ColxPt] = []
        var i = 0
        while i < 5 {
            pts.append(ColxPt { x: i, y: i })
            i = i + 1
        }
        var j = 0
        while j < pts.count {
            var local = pts[j]
            local.x = local.x * 2
            pts[j] = local
            j = j + 1
        }
        var s = 0
        var k = 0
        while k < pts.count {
            s = s + pts[k].x + pts[k].y
            k = k + 1
        }
        return s
    }
    // doubled x: 0+2+4+6+8=20, y unchanged: 0+1+2+3+4=10, total=30
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

