Test ColxIndexSwap {
    test {
        var xs: [Int] = []
        xs.append(1)
        xs.append(2)
        xs.append(3)
        let tmp = xs[0]
        xs[0] = xs[2]
        xs[2] = tmp
        return xs[0] * 10 + xs[2]
    }
    // xs[0]=3, xs[2]=1 -> 31
    expect { let e: Result<Int, TestFailure> = Result.Ok(31); return e }
}

