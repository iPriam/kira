Test ColxReverseFirst {
    test {
        let xs = colxBuildRange(5)
        let rev = colxReverse(xs)
        return rev[0]
    }
    // reversed [0,1,2,3,4] -> [4,3,2,1,0], first=4
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

Test ColxReverseLast {
    test {
        let xs = colxBuildRange(5)
        let rev = colxReverse(xs)
        return rev[4]
    }
    // last=0
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test ColxReverseSum {
    test {
        let xs = colxBuildRange(5)
        let rev = colxReverse(xs)
        return colxSum(rev)
    }
    // same elements, sum=10
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test ColxReverseCount {
    test {
        let xs = colxBuildRange(5)
        let rev = colxReverse(xs)
        return rev.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test ColxReverseSumManual {
    test {
        var xs: [Int] = []
        xs.append(3)
        xs.append(1)
        xs.append(4)
        xs.append(1)
        xs.append(5)
        let rev = colxReverse(xs)
        return colxSum(rev)
    }
    // 3+1+4+1+5 = 14
    expect { let e: Result<Int, TestFailure> = Result.Ok(14); return e }
}

Test ColxTrapReverseOOB {
    test {
        let xs = colxBuildRange(3)
        let rev = colxReverse(xs)
        let _ = rev[3]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

