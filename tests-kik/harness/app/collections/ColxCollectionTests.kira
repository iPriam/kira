// ---------------------------------------------------------------------------
// GROUP J - Allocation churn
// ---------------------------------------------------------------------------

Test ColxChurnRange100 {
    test {
        var total = 0
        var round = 0
        while round < 100 {
            let xs = colxBuildRange(5)
            total = total + colxSum(xs)
            round = round + 1
        }
        return total
    }
    // 10 per round * 100 = 1000
    expect { let e: Result<Int, TestFailure> = Result.Ok(1000); return e }
}

Test ColxChurnSquares50 {
    test {
        var total = 0
        var round = 0
        while round < 50 {
            let xs = colxBuildSquares(10)
            total = total + colxSum(xs)
            round = round + 1
        }
        return total
    }
    // 285 per round * 50 = 14250
    expect { let e: Result<Int, TestFailure> = Result.Ok(14250); return e }
}

Test ColxChurnFib30 {
    test {
        var total = 0
        var round = 0
        while round < 30 {
            let xs = colxBuildFib(8)
            total = total + colxSum(xs)
            round = round + 1
        }
        return total
    }
    // 33 per round * 30 = 990
    expect { let e: Result<Int, TestFailure> = Result.Ok(990); return e }
}

Test ColxChurnReverse20 {
    test {
        var total = 0
        var round = 0
        while round < 20 {
            let xs = colxBuildRange(8)
            let rev = colxReverse(xs)
            total = total + rev[0]
            round = round + 1
        }
        return total
    }
    // rev[0]=7 per round, 7*20=140
    expect { let e: Result<Int, TestFailure> = Result.Ok(140); return e }
}

Test ColxChurnStructs40 {
    test {
        var total = 0
        var round = 0
        while round < 40 {
            var pts: [ColxPt] = []
            var i = 0
            while i < 5 {
                pts.append(ColxPt { x: i, y: 0 })
                i = i + 1
            }
            var s = 0
            var j = 0
            while j < pts.count {
                s = s + pts[j].x
                j = j + 1
            }
            total = total + s
            round = round + 1
        }
        return total
    }
    // sum x = 10 per round * 40 = 400
    expect { let e: Result<Int, TestFailure> = Result.Ok(400); return e }
}

Test ColxChurnGrids25 {
    test {
        var total = 0
        var r = 0
        while r < 25 {
            var cells: [Int] = []
            cells.append(r)
            cells.append(r + 1)
            cells.append(r + 2)
            let grid = ColxGrid { cells: move cells }
            total = total + grid.sum()
            r = r + 1
        }
        return total
    }
    // r-th round sum=3r+3; total=sum(3r+3 for r=0..24)=3*(0+...+24)+3*25=3*300+75=975
    expect { let e: Result<Int, TestFailure> = Result.Ok(975); return e }
}

Test ColxChurnLarge200 {
    test {
        var total = 0
        var round = 0
        while round < 200 {
            let xs = colxBuildSquares(20)
            total = total + colxSum(xs)
            round = round + 1
        }
        return total
    }
    // sum(i^2 for i=0..19)=19*20*39/6=2470; 2470*200=494000
    expect { let e: Result<Int, TestFailure> = Result.Ok(494000); return e }
}

Test ColxChurnMixed30 {
    test {
        var total = 0
        var round = 0
        while round < 30 {
            let a = colxBuildRange(5)
            let b = colxBuildSquares(5)
            let c = colxBuildFib(5)
            total = total + colxSum(a) + colxSum(b) + colxSum(c)
            round = round + 1
        }
        return total
    }
    // range(5)=10, squares(5)=30, fib(5)=[0,1,1,2,3]=7; 47*30=1410
    expect { let e: Result<Int, TestFailure> = Result.Ok(1410); return e }
}

