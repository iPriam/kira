            cells.append(i)
            i = i + 1
        }
        let grid = ColxGrid { cells: move cells }
        return grid.sum()
    }
    // 0+1+...+99 = 4950
    expect { let e: Result<Int, TestFailure> = Result.Ok(4950); return e }
}

Test ColxGridMultiRowSum {
    test {
        // 3 grids with 4 cells each: grid r has cells r*4, r*4+1, r*4+2, r*4+3
        var total = 0
        var r = 0
        while r < 3 {
            var cells: [Int] = []
            var c = 0
            while c < 4 {
                cells.append(r * 4 + c)
                c = c + 1
            }
            let grid = ColxGrid { cells: move cells }
            total = total + grid.sum()
            r = r + 1
        }
        return total
    }
    // r=0: 0+1+2+3=6, r=1: 4+5+6+7=22, r=2: 8+9+10+11=38 -> 66
    expect { let e: Result<Int, TestFailure> = Result.Ok(66); return e }
}

