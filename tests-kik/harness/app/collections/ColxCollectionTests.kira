    test {
        var xs: [Int] = []
        xs.append(1)
        xs.append(2)
        xs.append(0)
        xs.append(3)
        xs.append(0)
        return colxCountGt(xs, 0)
    }
    // 1,2,3 -> 3
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

