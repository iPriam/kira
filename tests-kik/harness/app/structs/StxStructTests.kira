Test StxBagLoopTotal {
    // n=1..5: total(n)=n+n*(n+1)/2 → 2+5+9+14+20=50
    test {
        var acc = 0
        var n = 1
        while n <= 5 {
            var b = stxMakeBag(n)
            acc = acc + b.total()
            n = n + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(50); return e }
}

