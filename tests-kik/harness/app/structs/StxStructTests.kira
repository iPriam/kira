    expect { let e: Result<Int, TestFailure> = Result.Ok(25); return e }
}

// ---------------------------------------------------------------------------
// Group 4: Value-copy independence
// ---------------------------------------------------------------------------

Test StxCopyXIndep {
    // copy struct, mutate copy.x, original.x unchanged
    test {
        let p = StxPoint { x: 5, y: 3 }
        var q = p
        q.x = 99
        return p.x
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StxCopyYIndep {
    test {
        let p = StxPoint { x: 5, y: 3 }
        var q = p
        q.y = 77
        return p.y
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test StxCopyBothUnchanged {
    // copy, mutate both fields of copy, original sum unchanged
    test {
        let p = StxPoint { x: 5, y: 3 }
        var q = p
        q.x = 1
        q.y = 1
        return p.x + p.y
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(8); return e }
}

Test StxCopyNestedOriginX {
    test {
        let r = StxRect {
            origin: StxPoint { x: 10, y: 20 },
            size: StxPoint { x: 5, y: 5 },
            label: 0
        }
        var r2 = r
        r2.origin.x = 999
        return r.origin.x
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test StxCopyNestedSizeY {
    test {
        let r = StxRect {
            origin: StxPoint { x: 10, y: 20 },
            size: StxPoint { x: 5, y: 5 },
            label: 0
        }
        var r2 = r
        r2.size.y = 888
        return r.size.y
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test StxCopyMutateCopy {
    // original 5, copy gets 100; copy.x + original.x = 105
    test {
        let p = StxPoint { x: 5, y: 5 }
        var q = p
        q.x = 100
        return q.x + p.x
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(105); return e }
}

Test StxCopyBorrowMutNoEffect {
    // borrow mut on copy; original.x unchanged
    test {
        let p = StxPoint { x: 3, y: 4 }
        var q = p
        stxBumpX(q)
        return p.x
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test StxCopyLoopIndependence {
    // i=0..4: copy p={i,i}, zero copy.x, acc += p.x = i; sum=0+1+2+3+4=10
    test {
        var acc = 0
        var i = 0
        while i < 5 {
            let p = StxPoint { x: i, y: i }
            var q = p
            q.x = 0
            acc = acc + p.x
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test StxCopyScaleOriginalUnchanged {
    // scale returns new struct; original p.x unchanged
    test {
        let p = StxPoint { x: 3, y: 5 }
        let q = p.scale(10)
        return p.x
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test StxCopyCubeDepth {
    test {
        let c = StxCube {
            lo: StxPoint { x: 1, y: 2 },
            hi: StxPoint { x: 5, y: 6 },
            depth: 7
        }
        var c2 = c
        c2.depth = 999
        return c.depth
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

// ---------------------------------------------------------------------------
// Group 5: Arrays of structs
// ---------------------------------------------------------------------------

Test StxArrRead1X {
    // pts[1].x=3
    test {
        var pts: [StxPoint] = []
        pts.append(StxPoint { x: 1, y: 2 })
        pts.append(StxPoint { x: 3, y: 4 })
        pts.append(StxPoint { x: 5, y: 6 })
        return pts[1].x
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test StxArrRead2Y {
    // pts[2].y=6
    test {
        var pts: [StxPoint] = []
        pts.append(StxPoint { x: 1, y: 2 })
        pts.append(StxPoint { x: 3, y: 4 })
        pts.append(StxPoint { x: 5, y: 6 })
        return pts[2].y
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(6); return e }
}

Test StxArrSumX {
    // sum pts[i].x for i=0..2 = 1+3+5=9
    test {
        var pts: [StxPoint] = []
        pts.append(StxPoint { x: 1, y: 2 })
        pts.append(StxPoint { x: 3, y: 4 })
        pts.append(StxPoint { x: 5, y: 6 })
        var s = 0
        var i = 0
        while i < pts.count {
            s = s + pts[i].x
            i = i + 1
        }
        return s
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(9); return e }
}

Test StxArrForInSumY {
    // for-in: sum pts[i].y for i=0..2 = 2+4+6=12
    test {
        var pts: [StxPoint] = []
