// StxStructTests: deep struct tests — construction, field access, methods,
// borrow-mut writeback, value-copy independence, arrays of structs, and traps.
//
// All top-level names use the Stx/stx prefix to avoid harness namespace collisions.
// No `import Foundation` — main.kira imports it for the whole package.

// ---------------------------------------------------------------------------
// Struct definitions
// ---------------------------------------------------------------------------

struct StxPoint {
    var x: Int
    var y: Int

    function sum() -> Int { return self.x + self.y }
    function scale(k: Int) -> StxPoint { return StxPoint { x: self.x * k, y: self.y * k } }
    function product() -> Int { return self.x * self.y }
    function max() -> Int { return self.x > self.y ? self.x : self.y }
    function min() -> Int { return self.x < self.y ? self.x : self.y }
}

struct StxRect {
    var origin: StxPoint
    var size: StxPoint
    var label: Int

    function area() -> Int { return self.size.x * self.size.y }
    function perimeter() -> Int { return 2 * (self.size.x + self.size.y) }
    function labelPlusArea() -> Int { return self.label + self.area() }
}

struct StxCube {
    var lo: StxPoint
    var hi: StxPoint
    var depth: Int

    function volume() -> Int {
        return (self.hi.x - self.lo.x) * (self.hi.y - self.lo.y) * self.depth
    }
    function span() -> Int {
        return (self.hi.x - self.lo.x) + (self.hi.y - self.lo.y) + self.depth
    }
}

struct StxBag {
    var items: [Int]
    var tag: Int

    function total() -> Int {
        var s = self.tag
        var i = 0
        while i < self.items.count {
            s = s + self.items[i]
            i = i + 1
        }
        return s
    }
    function count() -> Int { return self.items.count }
}

// ---------------------------------------------------------------------------
// Top-level helper functions
// ---------------------------------------------------------------------------

function stxBumpX(p: borrow mut StxPoint) {
    p.x = p.x + 1
    return
}

function stxBumpY(p: borrow mut StxPoint) {
    p.y = p.y + 1
    return
}

function stxBumpBoth(p: borrow mut StxPoint) {
    p.x = p.x + 1
    p.y = p.y + 1
    return
}

function stxAddN(p: borrow mut StxPoint, n: Int) {
    p.x = p.x + n
    p.y = p.y + n
    return
}

function stxBumpRect(r: borrow mut StxRect) {
    r.label = r.label + 1
    r.origin.x = r.origin.x + 2
    r.size.y = r.size.y + 3
    return
}

function stxBumpCube(c: borrow mut StxCube) {
    c.depth = c.depth + 5
    c.lo.x = c.lo.x + 1
    return
}

function stxMakeBag(n: Int) -> StxBag {
    var xs: [Int] = []
    var i = 0
    while i < n {
        xs.append(i + 1)
        i = i + 1
    }
    return StxBag { items: move xs, tag: n }
}

function stxPointSum(p: borrow StxPoint) -> Int {
    return p.x + p.y
}

// ---------------------------------------------------------------------------
// Group 1: Basic construction + field access
// ---------------------------------------------------------------------------

Test StxConstX {
    test { let p = StxPoint { x: 3, y: 7 }; return p.x }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test StxConstY {
    test { let p = StxPoint { x: 3, y: 7 }; return p.y }
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

Test StxFieldAdd {
    test { let p = StxPoint { x: 5, y: 8 }; return p.x + p.y }
    expect { let e: Result<Int, TestFailure> = Result.Ok(13); return e }
}

Test StxFieldMul {
    test { let p = StxPoint { x: 4, y: 6 }; return p.x * p.y }
    expect { let e: Result<Int, TestFailure> = Result.Ok(24); return e }
}

Test StxFieldSub {
    test { let p = StxPoint { x: 10, y: 3 }; return p.x - p.y }
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

Test StxMutateX {
