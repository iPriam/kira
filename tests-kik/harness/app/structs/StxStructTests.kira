Test StxArrMixedWrites {
    // 4 pts, write to specific fields, sum=10+20+30+40=100
    test {
        var pts: [StxPoint] = []
        pts.append(StxPoint { x: 0, y: 0 })
        pts.append(StxPoint { x: 0, y: 0 })
        pts.append(StxPoint { x: 0, y: 0 })
        pts.append(StxPoint { x: 0, y: 0 })
        pts[0].x = 10
        pts[1].y = 20
        pts[2].x = 30
        pts[3].y = 40
        return pts[0].x + pts[1].y + pts[2].x + pts[3].y
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(100); return e }
}

Test StxArrLoop100 {
    // 100 pts where x=i, y=100-i; sum of p.sum()=100 each; total=10000
    test {
        var pts: [StxPoint] = []
        var i = 0
        while i < 100 {
            pts.append(StxPoint { x: i, y: 100 - i })
            i = i + 1
        }
        var acc = 0
        var j = 0
        while j < pts.count {
            acc = acc + pts[j].sum()
            j = j + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10000); return e }
}

Test StxArrCount {
    // append 7 pts, count=7
    test {
        var pts: [StxPoint] = []
        var i = 0
        while i < 7 {
            pts.append(StxPoint { x: i, y: 0 })
            i = i + 1
        }
        return pts.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

Test StxArrForInMethodSum {
    // i=0..4: p={x:i, y:i*2}, p.sum()=3i; total=0+3+6+9+12=30
    test {
        var pts: [StxPoint] = []
        var i = 0
        while i < 5 {
            pts.append(StxPoint { x: i, y: i * 2 })
            i = i + 1
        }
        var acc = 0
        for p in pts {
            acc = acc + p.sum()
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test StxArrAfterDeepWrite {
    // pts=[{x:1},{x:2},{x:3}], set pts[1].x=50, sum x = 1+50+3=54
    test {
        var pts: [StxPoint] = []
        pts.append(StxPoint { x: 1, y: 0 })
        pts.append(StxPoint { x: 2, y: 0 })
        pts.append(StxPoint { x: 3, y: 0 })
        pts[1].x = 50
        var s = 0
        var i = 0
        while i < pts.count {
            s = s + pts[i].x
            i = i + 1
        }
        return s
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(54); return e }
}

