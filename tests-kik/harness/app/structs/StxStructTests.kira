Test StxBorrowBumpX {
    test {
        var p = StxPoint { x: 5, y: 3 }
        stxBumpX(p)
        return p.x
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(6); return e }
}

Test StxBorrowBumpBoth {
    // p={5,3}, bumpBoth → {6,4}, sum=10
    test {
        var p = StxPoint { x: 5, y: 3 }
        stxBumpBoth(p)
        return p.x + p.y
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test StxBorrowBumpLoop {
    // p={0,0}, 10x bumpBoth → {10,10}, return p.x=10
    test {
        var p = StxPoint { x: 0, y: 0 }
        var i = 0
        while i < 10 {
            stxBumpBoth(p)
            i = i + 1
        }
        return p.x
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test StxBorrowBumpYSum {
    // p={5,3}, 5x bumpY → y=8
