        let st = colxaStatFrom(s)
        return st.sum
    }
    // sorted [1..9], sum=45
    expect { let e: Result<Int, TestFailure> = Result.Ok(45); return e }
}

Test ColxAPipelineReverseAndFilter {
    test {
        let xs = colxBuildRange(10)
        let rev = colxReverse(xs)
        let f = colxaFilterGt(rev, 6)
        return colxSum(f)
    }
    // rev=[9,8,...,0], filter>6=[9,8,7], sum=24
    expect { let e: Result<Int, TestFailure> = Result.Ok(24); return e }
}

Test ColxAPipelineSquaresSortFilter {
    test {
        let xs = colxBuildSquares(8)
        let s = colxaSorted(xs)
        let f = colxaFilterGt(s, 10)
        return colxSum(f)
    }
    // squares=[0,1,4,9,16,25,36,49], sorted same, >10=[16,25,36,49] sum=126
    expect { let e: Result<Int, TestFailure> = Result.Ok(126); return e }
}

Test ColxAPipelineChurn20 {
    test {
        var total = 0
        var r = 0
        while r < 20 {
            let xs = colxBuildRange(10)
            let f = colxaFilterGt(xs, 4)
            total = total + colxSum(f)
            r = r + 1
        }
        return total
    }
    // sum([5..9])=35, *20=700
    expect { let e: Result<Int, TestFailure> = Result.Ok(700); return e }
}

Test ColxAPipelineStatChurn15 {
    test {
        var totalSum = 0
        var r = 0
        while r < 15 {
            let xs = colxBuildRange(r + 2)
            let st = colxaStatFrom(xs)
            totalSum = totalSum + st.maxVal
            r = r + 1
        }
        return totalSum
    }
    // maxVal for range(r+2) = r+1, for r=0..14: 1+2+...+15=120
    expect { let e: Result<Int, TestFailure> = Result.Ok(120); return e }
}

// ---------------------------------------------------------------------------
// GROUP 6 – Dot product
// ---------------------------------------------------------------------------

Test ColxADotSimple {
    test {
        var xs: [Int] = []
        xs.append(1)
        xs.append(2)
        xs.append(3)
        var ys: [Int] = []
        ys.append(4)
        ys.append(5)
        ys.append(6)
        return colxaDot(xs, ys)
    }
    // 1*4+2*5+3*6 = 4+10+18 = 32
    expect { let e: Result<Int, TestFailure> = Result.Ok(32); return e }
}

Test ColxADotSelf {
    test {
        var xs: [Int] = []
        xs.append(2)
        xs.append(3)
        xs.append(4)
        var ys: [Int] = []
        ys.append(2)
        ys.append(3)
        ys.append(4)
        return colxaDot(xs, ys)
    }
    // 4+9+16 = 29
    expect { let e: Result<Int, TestFailure> = Result.Ok(29); return e }
}

Test ColxADotIdentity {
    test {
        let xs = colxBuildRange(5)
        var ones: [Int] = []
        ones.append(1)
        ones.append(1)
        ones.append(1)
        ones.append(1)
        ones.append(1)
        return colxaDot(xs, ones)
    }
    // dot with [1,1,1,1,1] = sum = 0+1+2+3+4 = 10
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test ColxADotSquares {
    test {
        let xs = colxBuildRange(5)
        let ys = colxBuildRange(5)
        return colxaDot(xs, ys)
    }
    // sum(i*i for i=0..4) = 0+1+4+9+16 = 30
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test ColxADotEmpty {
    test {
        let xs: [Int] = []
        let ys: [Int] = []
        return colxaDot(xs, ys)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

// ---------------------------------------------------------------------------
// GROUP 7 – Extended ColxPt / ColxGrid usage
// ---------------------------------------------------------------------------

Test ColxAPtFilteredSumXY {
    test {
        // 10 pts {x:i, y:i} for i=0..9; sum x+y for pts where x>5
        var pts: [ColxPt] = []
        var i = 0
        while i < 10 {
            pts.append(ColxPt { x: i, y: i })
            i = i + 1
        }
        var s = 0
        var j = 0
        while j < pts.count {
            if pts[j].x > 5 {
                s = s + pts[j].x + pts[j].y
            }
            j = j + 1
        }
        return s
    }
    // pts with x>5: x=6,7,8,9; x+y=(6+6)+(7+7)+(8+8)+(9+9)=12+14+16+18=60
    expect { let e: Result<Int, TestFailure> = Result.Ok(60); return e }
}

Test ColxAGridChurnSum {
    test {
        var total = 0
        var r = 0
        while r < 10 {
            let cells = colxBuildRange(r + 1)
            let grid = ColxGrid { cells: move cells }
            total = total + grid.sum()
            r = r + 1
        }
        return total
    }
    // r=0: sum=0, r=1: sum=1, r=2: sum=3, ..., r=9: sum=45
    // sums = 0,1,3,6,10,15,21,28,36,45 -> total=165
    expect { let e: Result<Int, TestFailure> = Result.Ok(165); return e }
}

Test ColxABoxStatSum {
    test {
        // Build 8 boxes (lo=i, hi=i+i+2), sum their sizes
        var s = 0
        var i = 0
        while i < 8 {
            let box = ColxBox { lo: i, hi: i + i + 2 }
            s = s + box.size()
            i = i + 1
        }
        return s
    }
    // size = hi-lo = (i+i+2)-i = i+2; sum(i+2 for i=0..7) = (0+2)+(1+2)+...+(7+2) = 28+16 = 44
    // Actually: sum(i+2) = sum(i) + 2*8 = 28 + 16 = 44
    expect { let e: Result<Int, TestFailure> = Result.Ok(44); return e }
}

Test ColxACombinedChecksum {
    test {
        // Combined: range + filter + stat + sort
        let xs = colxBuildRange(15)
        let f = colxaFilterGt(xs, 7)
        let s = colxaSorted(f)
        let st = colxaStatFrom(s)
        return st.sum + st.count + s[0]
    }
    // >7=[8,9,10,11,12,13,14], count=7, sum=77, sorted[0]=8 -> 77+7+8=92
    expect { let e: Result<Int, TestFailure> = Result.Ok(92); return e }
}

// ---------------------------------------------------------------------------
// GROUP 8 – Trap tests
// ---------------------------------------------------------------------------

Test ColxATrapSortedOOB {
    test {
        var xs: [Int] = []
        xs.append(3)
        xs.append(1)
        xs.append(2)
        let s = colxaSorted(xs)
        let _ = s[3]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test ColxATrapFilteredEmptyOOB {
    test {
        let xs = colxBuildRange(5)
        let f = colxaFilterGt(xs, 100)
        let _ = f[0]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test ColxATrapDivByArrayElement {
    test {
        var xs: [Int] = []
        xs.append(5)
        xs.append(0)
        xs.append(3)
        var acc = 0
        var i = 0
        while i < xs.count {
            acc = acc + 10 / xs[i]
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test ColxATrapStatFromOOB {
    test {
        let xs = colxBuildRange(5)
        let st = colxaStatFrom(xs)
        // Use count (=5) as index into range(5) -> OOB
        let _ = xs[st.count]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test ColxATrapRowEmpty {
    test {
        let vals: [Int] = []
        let row = ColxARow { vals: move vals }
        // Access index 0 of empty vals via count trick
        var xs: [Int] = []
        let n = row.rowCount()
        let _ = xs[n]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test ColxATrapModByZero {
    test {
        var xs: [Int] = []
        xs.append(0)
        let result = 17 % xs[0]
        return result
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test ColxATrapDivZeroLiteral {
    test {
        let x = 42 / 0
        return x
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test ColxATrapWriteOOB {
    test {
        var xs: [Int] = []
        xs.append(1)
        xs.append(2)
        xs.append(3)
        xs[3] = 99
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test ColxATrapDotOOBAccess {
    test {
        var xs: [Int] = []
        xs.append(1)
        xs.append(2)
        var ys: [Int] = []
        ys.append(3)
        // colxaDot will try xs[1]*ys[1] but ys only has 1 element -> OOB
        let result = colxaDot(xs, ys)
        return result
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test ColxATrapRangeOOBByCount {
    test {
        let xs = colxBuildRange(7)
        let _ = xs[xs.count]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}
