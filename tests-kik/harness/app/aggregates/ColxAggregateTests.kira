Test ColxARowEmpty {
    test {
        let vals: [Int] = []
        let row = ColxARow { vals: move vals }
        return row.rowSum() + row.rowCount()
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test ColxARowMatrixTotalSum {
    test {
        // 5 rows of 4 cells: row r has cells r*4, r*4+1, r*4+2, r*4+3
        var total = 0
        var r = 0
        while r < 5 {
            var vals: [Int] = []
            var c = 0
            while c < 4 {
                vals.append(r * 4 + c)
                c = c + 1
            }
            let row = ColxARow { vals: move vals }
            total = total + row.rowSum()
            r = r + 1
        }
        return total
    }
    // r=0:6, r=1:22, r=2:38, r=3:54, r=4:70 -> 190
    expect { let e: Result<Int, TestFailure> = Result.Ok(190); return e }
}

Test ColxARowMatrixRowCounts {
    test {
        var totalCells = 0
        var r = 0
        while r < 5 {
            var vals: [Int] = []
            var c = 0
            while c < r + 1 {
                vals.append(c)
                c = c + 1
            }
            let row = ColxARow { vals: move vals }
            totalCells = totalCells + row.rowCount()
            r = r + 1
        }
        return totalCells
    }
    // row counts: 1+2+3+4+5=15
    expect { let e: Result<Int, TestFailure> = Result.Ok(15); return e }
}

Test ColxARowSquaresSum {
    test {
        let vals = colxBuildSquares(5)
        let row = ColxARow { vals: move vals }
        return row.rowSum()
    }
    // [0,1,4,9,16] -> 30
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test ColxARowFibSum {
    test {
        let vals = colxBuildFib(8)
        let row = ColxARow { vals: move vals }
        return row.rowSum()
    }
    // [0,1,1,2,3,5,8,13] -> 33
    expect { let e: Result<Int, TestFailure> = Result.Ok(33); return e }
}

Test ColxARowChurn30 {
    test {
        var total = 0
        var r = 0
        while r < 30 {
            let vals = colxBuildSquares(6)
            let row = ColxARow { vals: move vals }
            total = total + row.rowSum()
            r = r + 1
        }
        return total
    }
    // squares(6)=[0,1,4,9,16,25] sum=55; 55*30=1650
    expect { let e: Result<Int, TestFailure> = Result.Ok(1650); return e }
}

