Test ColxASortedDuplicates {
    test {
        var xs: [Int] = []
        xs.append(7)
        xs.append(7)
        xs.append(3)
        xs.append(7)
        xs.append(3)
        xs.append(1)
        let s = colxaSorted(xs)
        return s[0] + s[5]
    }
    // sorted=[1,3,3,7,7,7] -> s[0]=1, s[5]=7 -> 8
    expect { let e: Result<Int, TestFailure> = Result.Ok(8); return e }
}

Test ColxASortedDuplicatesSum {
    test {
        var xs: [Int] = []
        xs.append(7)
        xs.append(7)
        xs.append(3)
        xs.append(7)
        xs.append(3)
        xs.append(1)
        let s = colxaSorted(xs)
        return colxSum(s)
    }
    // 1+3+3+7+7+7=28
    expect { let e: Result<Int, TestFailure> = Result.Ok(28); return e }
}

Test ColxASortedTwo {
    test {
        var xs: [Int] = []
        xs.append(100)
        xs.append(1)
        let s = colxaSorted(xs)
        return s[0] * 1000 + s[1]
    }
    // sorted=[1,100] -> 1*1000+100=1100
    expect { let e: Result<Int, TestFailure> = Result.Ok(1100); return e }
}

Test ColxASortedSingle {
    test {
        var xs: [Int] = []
        xs.append(42)
        let s = colxaSorted(xs)
        return s[0]
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

Test ColxASortedAlreadySorted {
    test {
        let xs = colxBuildRange(8)
        let s = colxaSorted(xs)
        return s[0] + s[7]
    }
    // [0,1,2,3,4,5,6,7] sorted = same -> s[0]=0, s[7]=7 -> 7
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

Test ColxASortedReverseInput {
    test {
        // Build [9,8,7,6,5,4,3,2,1,0]
        var xs: [Int] = []
        var i = 9
        while i >= 0 {
            xs.append(i)
            i = i - 1
        }
        let s = colxaSorted(xs)
        return s[0] + s[9]
    }
    // sorted=[0..9], s[0]=0, s[9]=9 -> 9
    expect { let e: Result<Int, TestFailure> = Result.Ok(9); return e }
}

Test ColxASortedCount {
    test {
        var xs: [Int] = []
        xs.append(3)
        xs.append(1)
        xs.append(4)
        let s = colxaSorted(xs)
        return s.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

