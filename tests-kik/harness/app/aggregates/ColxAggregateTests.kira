// ColxAggregateTests.kira
// Aggregate pipeline test suite. All new names use colxa / ColxA prefix.
// Reuses colxSum, colxBuildRange, colxBuildSquares, colxBuildFib, ColxPt,
// ColxGrid, ColxBox from ColxCollectionTests.kira (same package namespace).
// ~72 tests (including ~10 trap tests).

// ---------------------------------------------------------------------------
// New struct types
// ---------------------------------------------------------------------------

struct ColxAStat {
    var count: Int
    var sum: Int
    var minVal: Int
    var maxVal: Int
}

struct ColxARow {
    var vals: [Int]

    function rowSum() -> Int {
        var t = 0
        var i = 0
        while i < self.vals.count {
            t = t + self.vals[i]
            i = i + 1
        }
        return t
    }

    function rowCount() -> Int {
        return self.vals.count
    }
}

// ---------------------------------------------------------------------------
// New helper functions
// ---------------------------------------------------------------------------

// Accumulate one value into a running stat.
function colxaAccumStat(stat: borrow mut ColxAStat, val: Int) {
    if stat.count == 0 {
        stat.minVal = val
        stat.maxVal = val
    } else {
        if val < stat.minVal {
            stat.minVal = val
        }
        if val > stat.maxVal {
            stat.maxVal = val
        }
    }
    stat.count = stat.count + 1
    stat.sum = stat.sum + val
    return
}

// Build a stat from an array.
function colxaStatFrom(xs: borrow [Int]) -> ColxAStat {
    var count = 0
    var sum = 0
    var minVal = 0
    var maxVal = 0
    var i = 0
    while i < xs.count {
        let v = xs[i]
        if count == 0 {
            minVal = v
            maxVal = v
        } else {
            if v < minVal { minVal = v }
            if v > maxVal { maxVal = v }
        }
        count = count + 1
        sum = sum + v
        i = i + 1
    }
    return ColxAStat { count: count, sum: sum, minVal: minVal, maxVal: maxVal }
}

// Return a sorted copy using bubble sort.
function colxaSorted(xs: borrow [Int]) -> [Int] {
    var out: [Int] = []
    var i = 0
    while i < xs.count {
        out.append(xs[i])
        i = i + 1
    }
    var n = out.count
    var p = 0
    while p < n {
        var q = 0
        while q < n - 1 - p {
            if out[q] > out[q + 1] {
                let tmp = out[q]
                out[q] = out[q + 1]
                out[q + 1] = tmp
            }
            q = q + 1
        }
        p = p + 1
    }
    return out
}

// Filter: keep elements strictly greater than thresh.
function colxaFilterGt(xs: borrow [Int], thresh: Int) -> [Int] {
    var out: [Int] = []
    var i = 0
    while i < xs.count {
        if xs[i] > thresh {
            out.append(xs[i])
        }
        i = i + 1
    }
    return out
}

// Filter: keep elements strictly less than thresh.
function colxaFilterLt(xs: borrow [Int], thresh: Int) -> [Int] {
    var out: [Int] = []
    var i = 0
    while i < xs.count {
        if xs[i] < thresh {
            out.append(xs[i])
        }
        i = i + 1
    }
    return out
}

// Dot product of two equal-length arrays.
function colxaDot(xs: borrow [Int], ys: borrow [Int]) -> Int {
    var s = 0
    var i = 0
    while i < xs.count {
        s = s + xs[i] * ys[i]
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// GROUP 1 – Running statistics with ColxAStat
// ---------------------------------------------------------------------------

Test ColxAStatSumRange10 {
    test {
        let xs = colxBuildRange(10)
        let st = colxaStatFrom(xs)
        return st.sum
    }
    // [0..9] sum=45
    expect { let e: Result<Int, TestFailure> = Result.Ok(45); return e }
}

Test ColxAStatCountRange10 {
    test {
        let xs = colxBuildRange(10)
        let st = colxaStatFrom(xs)
        return st.count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test ColxAStatMinRange10 {
    test {
        let xs = colxBuildRange(10)
        let st = colxaStatFrom(xs)
        return st.minVal
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test ColxAStatMaxRange10 {
    test {
        let xs = colxBuildRange(10)
        let st = colxaStatFrom(xs)
        return st.maxVal
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(9); return e }
}

Test ColxAStatSumPlusCountPlusMax {
    test {
        let xs = colxBuildRange(10)
        let st = colxaStatFrom(xs)
        return st.sum + st.count + st.maxVal
    }
    // 45+10+9=64
    expect { let e: Result<Int, TestFailure> = Result.Ok(64); return e }
}

Test ColxAStatFromLiteral {
    test {
        var xs: [Int] = []
        xs.append(3)
        xs.append(1)
        xs.append(4)
        xs.append(1)
        xs.append(5)
        xs.append(9)
        xs.append(2)
        xs.append(6)
        xs.append(5)
        xs.append(3)
        let st = colxaStatFrom(xs)
        return st.maxVal - st.minVal
    }
    // [3,1,4,1,5,9,2,6,5,3] sum=39, min=1, max=9 -> 8
    expect { let e: Result<Int, TestFailure> = Result.Ok(8); return e }
}

Test ColxAStatSumLiteral {
    test {
        var xs: [Int] = []
        xs.append(3)
        xs.append(1)
        xs.append(4)
        xs.append(1)
        xs.append(5)
        xs.append(9)
        xs.append(2)
        xs.append(6)
        xs.append(5)
        xs.append(3)
        let st = colxaStatFrom(xs)
        return st.sum
    }
    // 3+1+4+1+5+9+2+6+5+3 = 39
    expect { let e: Result<Int, TestFailure> = Result.Ok(39); return e }
}

Test ColxAStatSingle {
    test {
        var xs: [Int] = []
        xs.append(42)
        let st = colxaStatFrom(xs)
        return st.sum + st.count + st.minVal + st.maxVal
    }
    // sum=42, count=1, min=42, max=42 -> 127
    expect { let e: Result<Int, TestFailure> = Result.Ok(127); return e }
}

Test ColxAStatRange20Sum {
    test {
        let xs = colxBuildRange(20)
        let st = colxaStatFrom(xs)
        return st.sum - st.count
    }
    // sum=190, count=20 -> 170
    expect { let e: Result<Int, TestFailure> = Result.Ok(170); return e }
}

Test ColxAStatEvenOnly {
    test {
        var xs: [Int] = []
        xs.append(2)
        xs.append(4)
        xs.append(6)
        xs.append(8)
        xs.append(10)
        let st = colxaStatFrom(xs)
        return st.sum + st.count + st.maxVal - st.minVal
    }
    // sum=30, count=5, max=10, min=2 -> 30+5+10-2=43
    expect { let e: Result<Int, TestFailure> = Result.Ok(43); return e }
}

Test ColxAStatAccumLoop {
    test {
        var stat = ColxAStat { count: 0, sum: 0, minVal: 0, maxVal: 0 }
        var i = 0
        while i < 5 {
            colxaAccumStat(stat, i * 2 + 1)
            i = i + 1
        }
        return stat.sum
    }
    // values: 1,3,5,7,9 -> sum=25
    expect { let e: Result<Int, TestFailure> = Result.Ok(25); return e }
}

Test ColxAStatAccumMin {
    test {
        var stat = ColxAStat { count: 0, sum: 0, minVal: 0, maxVal: 0 }
        colxaAccumStat(stat, 10)
        colxaAccumStat(stat, 3)
        colxaAccumStat(stat, 7)
        colxaAccumStat(stat, 1)
        colxaAccumStat(stat, 5)
        return stat.minVal
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

Test ColxAStatAccumMax {
    test {
        var stat = ColxAStat { count: 0, sum: 0, minVal: 0, maxVal: 0 }
        colxaAccumStat(stat, 10)
        colxaAccumStat(stat, 3)
        colxaAccumStat(stat, 7)
        colxaAccumStat(stat, 1)
        colxaAccumStat(stat, 5)
        return stat.maxVal
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test ColxAStatFromSquares {
    test {
        let xs = colxBuildSquares(6)
        let st = colxaStatFrom(xs)
        return st.maxVal
    }
    // [0,1,4,9,16,25] -> max=25
    expect { let e: Result<Int, TestFailure> = Result.Ok(25); return e }
}

Test ColxAStatChurn50 {
    test {
        var grandSum = 0
        var r = 0
        while r < 50 {
            let xs = colxBuildRange(r + 1)
            let st = colxaStatFrom(xs)
            grandSum = grandSum + st.sum
            r = r + 1
        }
        return grandSum
    }
    // sum(sum(0..r) for r=0..49) = sum(r*(r+1)/2 for r=0..49)
    // = 0+1+3+6+10+...+1225
    // = sum(r*(r+1)/2) = (1/2)*sum(r^2+r) = (1/2)*(sum_r^2 + sum_r)
    // sum(r^2 for r=0..49) = 49*50*99/6 = 40425
    // sum(r for r=0..49) = 1225
    // total = (40425+1225)/2 = 41650/2 = 20825
    expect { let e: Result<Int, TestFailure> = Result.Ok(20825); return e }
}

