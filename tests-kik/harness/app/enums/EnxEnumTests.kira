// EnxItem{Low, 4} -> 4
Test EnxItemScoreLow {
    test {
        let item = EnxItem { priority: EnxPriority.Low, value: 4 }
        return enxItemScore(item)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

// EnxItem{Medium, 3} -> 15
Test EnxItemScoreMedium {
    test {
        let item = EnxItem { priority: EnxPriority.Medium, value: 3 }
        return enxItemScore(item)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(15); return e }
}

// EnxItem{High, 2} -> 20
Test EnxItemScoreHigh {
    test {
        let item = EnxItem { priority: EnxPriority.High, value: 2 }
        return enxItemScore(item)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(20); return e }
}

// [L(2),M(3),H(1),L(4),H(2),M(1)] -> 2+15+10+4+20+5=56
Test EnxItemLiteralArrayFold {
    test {
        let items: [EnxItem] = [
            EnxItem { priority: EnxPriority.Low,    value: 2 },
            EnxItem { priority: EnxPriority.Medium, value: 3 },
            EnxItem { priority: EnxPriority.High,   value: 1 },
            EnxItem { priority: EnxPriority.Low,    value: 4 },
            EnxItem { priority: EnxPriority.High,   value: 2 },
            EnxItem { priority: EnxPriority.Medium, value: 1 }
        ]
        var s = 0
        for item in items {
            s = s + enxItemScore(item)
        }
        return s
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(56); return e }
}

// Dynamic build: i=0..5, item{priorityFor(i%3), value: i+1}
// i=0:L,v=1->1; i=1:M,v=2->10; i=2:H,v=3->30; i=3:L,v=4->4; i=4:M,v=5->25; i=5:H,v=6->60
// sum=130
Test EnxItemDynFold {
    test {
        var acc = 0
        var i = 0
        while i < 6 {
            let item = EnxItem { priority: enxPriorityFor(i), value: i + 1 }
            acc = acc + enxItemScore(item)
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(130); return e }
}

// ---------------------------------------------------------------------------
// Combined / cross-enum tests
// ---------------------------------------------------------------------------

// sum (enxDirWeight(enxDirFor(i)) + enxSeasonCode(enxSeasonFor(i))) for i=0..7:
// i=0: N(1)+Spr(10)=11, i=1: S(2)+Sum(20)=22, i=2: E(3)+Aut(30)=33, i=3: W(4)+Win(40)=44
// i=4: N(1)+Spr(10)=11, i=5: S(2)+Sum(20)=22, i=6: E(3)+Aut(30)=33, i=7: W(4)+Win(40)=44
// sum=220
Test EnxDirSeasonCombinedFold {
    test {
        var acc = 0
        var i = 0
        while i < 8 {
            let dw = enxDirWeight(enxDirFor(i))
            let sc = enxSeasonCode(enxSeasonFor(i))
            acc = acc + dw + sc
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(220); return e }
}

// sum (enxTokenVal(enxTokenFor(i)) + enxPriorityScore(enxPriorityFor(i))) for i=0..5:
// i=0:Num(0)->0+Low->1=1
// i=1:Paren(1)->2+Med->5=7
// i=2:Op(2)->6+High->10=16
// i=3:Num(3)->3+Low->1=4
// i=4:Paren(4)->8+Med->5=13
// i=5:Op(5)->15+High->10=25
// sum=66
Test EnxTokenPriorityPairFold {
    test {
        var acc = 0
        var i = 0
        while i < 6 {
            let tv = enxTokenVal(enxTokenFor(i))
            let pv = enxPriorityScore(enxPriorityFor(i))
            acc = acc + tv + pv
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(66); return e }
}

// Dirs 0..11 + Seasons 0..11:
// dirs: 3*(1+2+3+4)=30, seasons: 3*(10+20+30+40)=300 -> 330
Test EnxDirPlusSeasonFolds {
    test {
        var dirAcc = 0
        var seaAcc = 0
        var i = 0
        while i < 12 {
            dirAcc = dirAcc + enxDirWeight(enxDirFor(i))
            seaAcc = seaAcc + enxSeasonCode(enxSeasonFor(i))
            i = i + 1
        }
        return dirAcc + seaAcc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(330); return e }
}

// Nested: for each priority band, sum token values with that priority weight as multiplier.
// i=0..8: token(i) value * priorityScore(priorityFor(i))
// i=0:Num(0)*L(1)=0, i=1:Paren(1)*M(5)=10, i=2:Op(2)*H(10)=60
// i=3:Num(3)*L(1)=3, i=4:Paren(4)*M(5)=40, i=5:Op(5)*H(10)=150
// i=6:Num(6)*L(1)=6, i=7:Paren(7)*M(5)=70, i=8:Op(8)*H(10)=240
// sum=0+10+60+3+40+150+6+70+240=579
Test EnxTokenPriorityMultiplyFold {
    test {
        var acc = 0
        var i = 0
        while i < 9 {
            let tv = enxTokenVal(enxTokenFor(i))
            let ps = enxPriorityScore(enxPriorityFor(i))
            acc = acc + tv * ps
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(579); return e }
}

// Event scores + dir weights for same index i=0..5:
// i=0: Click(0)=0+North=1=1... wait, EnxEvent doesn't have a For function.
// Let me just do [Click(1),Key(1),Scroll(1),Idle,Click(2),Key(2)] scores=1+10+100+0+2+20=133
// plus Dir 0..5 weights: 1+2+3+4+1+2=13
// total=146
Test EnxEventPlusDirFold {
    test {
        let es: [EnxEvent] = [EnxEvent.Click(1), EnxEvent.Key(1), EnxEvent.Scroll(1), EnxEvent.Idle, EnxEvent.Click(2), EnxEvent.Key(2)]
        var eAcc = 0
        for ev in es {
            eAcc = eAcc + enxEventScore(ev)
        }
        var dAcc = 0
        var i = 0
        while i < 6 {
            dAcc = dAcc + enxDirWeight(enxDirFor(i))
            i = i + 1
        }
        return eAcc + dAcc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(146); return e }
}

// ---------------------------------------------------------------------------
// State-machine-style tests (Status transitions as scalar sequence)
// ---------------------------------------------------------------------------

// Simulate: 3 steps of Running(n) advancing n by 5 each step, check final code
// n0=7, n1=12, n2=17: code of Running(17)=17
Test EnxStatusRunningProgress {
    test {
        var n = 7
        var steps = 0
        while steps < 3 {
            n = n + 5
            steps = steps + 1
        }
        return enxStatusCode(EnxStatus.Running(n))
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(22); return e }
}

// Status code sum for a specific sequence:
// [Dormant, Running(3), Running(6), Done(3), Failed(1), Done(10)]
// codes: 0+3+6+103+(-1)+110=221
Test EnxStatusSequenceFold {
    test {
        let ss: [EnxStatus] = [
            EnxStatus.Dormant,
            EnxStatus.Running(3),
            EnxStatus.Running(6),
            EnxStatus.Done(3),
            EnxStatus.Failed(1),
            EnxStatus.Done(10)
        ]
        var acc = 0
        for s in ss {
            acc = acc + enxStatusCode(s)
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(221); return e }
}

// Max status code in [Running(5), Done(2), Running(8), Failed(3)]:
// codes: 5, 102, 8, -3 -> max=102
Test EnxStatusMaxCode {
    test {
        let ss: [EnxStatus] = [EnxStatus.Running(5), EnxStatus.Done(2), EnxStatus.Running(8), EnxStatus.Failed(3)]
        var mx = 0 - 99999
        for s in ss {
            let c = enxStatusCode(s)
            if c > mx { mx = c }
        }
        return mx
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(102); return e }
}

// ---------------------------------------------------------------------------
// TRAP tests
// ---------------------------------------------------------------------------

// OOB on array of EnxDir
Test EnxTrapDirArrayOOB {
    test {
        let ds: [EnxDir] = [EnxDir.North, EnxDir.South, EnxDir.East]
        let _ = enxDirWeight(ds[10])
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// OOB on array of EnxToken
Test EnxTrapTokenArrayOOB {
    test {
        let ts: [EnxToken] = [EnxToken.Num(1), EnxToken.Paren(2)]
        let _ = enxTokenVal(ts[5])
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// OOB on array of EnxStatus
Test EnxTrapStatusArrayOOB {
    test {
        var ss: [EnxStatus] = []
        ss.append(EnxStatus.Dormant)
        ss.append(EnxStatus.Running(1))
        let _ = enxStatusCode(ss[100])
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// Div by zero derived from enum payload: Token.Num(0) -> val=0, then 10/val
Test EnxTrapDivByTokenPayload {
    test {
        let t = EnxToken.Num(0)
        let val = enxTokenVal(t)
        return 10 / val
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// Mod by zero derived from enum payload
Test EnxTrapModByTokenPayload {
    test {
        let t = EnxToken.Op(0)
        let val = enxTokenVal(t)
        return 42 % val
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// OOB on empty EnxNode array
Test EnxTrapNodeEmptyArrayOOB {
    test {
        let ns: [EnxNode] = []
        let _ = enxNodeVal(ns[0])
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// Div zero via status payload: Failed(0) -> code = 0-0 = 0, then 5/0
Test EnxTrapDivByStatusCode {
    test {
        let s = EnxStatus.Failed(0)
        let code = enxStatusCode(s)
        return 5 / code
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// OOB via computed index from enum: Leaf(100) -> val=100, index into 3-elem array
Test EnxTrapOOBFromLeafPayload {
    test {
        let n = EnxNode.Leaf(100)
        let idx = enxNodeVal(n)
        let xs: [Int] = [1, 2, 3]
        let _ = xs[idx]
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// OOB in loop that scans an array of EnxEvent with wrong count
Test EnxTrapEventOOBInLoop {
    test {
        let events: [EnxEvent] = [EnxEvent.Click(1), EnxEvent.Idle]
        var acc = 0
        var i = 0
        while i < 10 {
            acc = acc + enxEventScore(events[i])
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

// Div zero from direction weight difference: North(1)-North(1)=0, then 7/(w1-w2)
Test EnxTrapDivByDirDiff {
    test {
        let d1 = EnxDir.North
        let d2 = EnxDir.North
        let diff = enxDirWeight(d1) - enxDirWeight(d2)
        return 7 / diff
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}
