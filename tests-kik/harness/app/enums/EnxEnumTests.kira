// EnxEnumTests.kira — Deep enum test suite.
// Covers: payload-less enums (4-variant, 3-variant, 4-variant), single-payload
// Int enums, mixed payload/payload-less enums, enums as struct fields, arrays
// of enums matched via borrow-param helpers, state-machine transitions, and
// trap tests.  All top-level names use prefix enx / Enx.

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum EnxDir {
    North
    South
    East
    West
}

enum EnxPriority {
    Low
    Medium
    High
}

enum EnxSeason {
    Spring
    Summer
    Autumn
    Winter
}

enum EnxToken {
    Num(Int)
    Paren(Int)
    Op(Int)
}

enum EnxEvent {
    Click(Int)
    Key(Int)
    Scroll(Int)
    Idle
}

// Mixed: one payload-less variant + three single-Int variants.
enum EnxStatus {
    Dormant
    Running(Int)
    Done(Int)
    Failed(Int)
}

// Three variants: two payload, one payload-less.
enum EnxNode {
    Leaf(Int)
    Tagged(Int)
    Empty
}

// ---------------------------------------------------------------------------
// Structs
// ---------------------------------------------------------------------------

struct EnxItem {
    var priority: EnxPriority
    var value: Int
}

// ---------------------------------------------------------------------------
// Helper functions — enums returned DIRECTLY from each branch (never via
// a mutable local that is reassigned, which miscompiles on LLVM).
// ---------------------------------------------------------------------------

function enxDirWeight(d: borrow EnxDir) -> Int {
    match d {
        North -> { return 1 }
        South -> { return 2 }
        East  -> { return 3 }
        West  -> { return 4 }
    }
}

// Returns an EnxDir for index i (by switch so variant comes from each arm).
function enxDirFor(i: Int) -> EnxDir {
    switch i % 4 {
        case 0 { return EnxDir.North }
        case 1 { return EnxDir.South }
        case 2 { return EnxDir.East }
        case 3 { return EnxDir.West }
        default { return EnxDir.North }
    }
}

function enxPriorityScore(p: borrow EnxPriority) -> Int {
    match p {
        Low    -> { return 1 }
        Medium -> { return 5 }
        High   -> { return 10 }
    }
}

function enxPriorityFor(i: Int) -> EnxPriority {
    switch i % 3 {
        case 0 { return EnxPriority.Low }
        case 1 { return EnxPriority.Medium }
        case 2 { return EnxPriority.High }
        default { return EnxPriority.Low }
    }
}

function enxSeasonCode(s: borrow EnxSeason) -> Int {
    match s {
        Spring -> { return 10 }
        Summer -> { return 20 }
        Autumn -> { return 30 }
        Winter -> { return 40 }
    }
}

function enxSeasonFor(i: Int) -> EnxSeason {
    switch i % 4 {
        case 0 { return EnxSeason.Spring }
        case 1 { return EnxSeason.Summer }
        case 2 { return EnxSeason.Autumn }
        case 3 { return EnxSeason.Winter }
        default { return EnxSeason.Spring }
    }
}

function enxTokenVal(t: borrow EnxToken) -> Int {
    match t {
        Num(v)   -> { return v }
        Paren(v) -> { return v * 2 }
        Op(v)    -> { return v * 3 }
    }
}

function enxTokenFor(i: Int) -> EnxToken {
    switch i % 3 {
        case 0 { return EnxToken.Num(i) }
        case 1 { return EnxToken.Paren(i) }
        case 2 { return EnxToken.Op(i) }
        default { return EnxToken.Num(0) }
    }
}

function enxEventScore(e: borrow EnxEvent) -> Int {
    match e {
        Click(v)  -> { return v }
        Key(v)    -> { return v * 10 }
        Scroll(v) -> { return v * 100 }
        Idle      -> { return 0 }
    }
}

// Returns status code: Dormant=0, Running(n)=n, Done(n)=n+100, Failed(n)=-(n)
function enxStatusCode(s: borrow EnxStatus) -> Int {
    match s {
        Dormant    -> { return 0 }
        Running(n) -> { return n }
        Done(n)    -> { return n + 100 }
        Failed(n)  -> { return 0 - n }
    }
}

function enxStatusFor(i: Int) -> EnxStatus {
    switch i % 4 {
        case 0 { return EnxStatus.Dormant }
        case 1 { return EnxStatus.Running(i) }
        case 2 { return EnxStatus.Done(i) }
        case 3 { return EnxStatus.Failed(i) }
        default { return EnxStatus.Dormant }
    }
}

function enxNodeVal(n: borrow EnxNode) -> Int {
    match n {
        Leaf(v)   -> { return v }
        Tagged(v) -> { return v * 10 }
        Empty     -> { return 0 }
    }
}

// Scoring an EnxItem: Low uses raw value, Medium*5, High*10.
function enxItemScore(item: borrow EnxItem) -> Int {
    match item.priority {
        Low    -> { return item.value }
        Medium -> { return item.value * 5 }
        High   -> { return item.value * 10 }
    }
}

// Helpers for for-in / indexed matching (KSEM104: cannot match arr[i] or
// for-in bindings directly — must pass through a borrow-param function).

function enxIsIdleEvent(e: borrow EnxEvent) -> Int {
    match e {
        Idle      -> { return 1 }
        Click(v)  -> { return 0 }
        Key(v)    -> { return 0 }
        Scroll(v) -> { return 0 }
    }
}

function enxClickPayload(e: borrow EnxEvent) -> Int {
    match e {
        Click(v)  -> { return v }
        Key(v)    -> { return 0 }
        Scroll(v) -> { return 0 }
        Idle      -> { return 0 }
    }
}

function enxIsLeaf(n: borrow EnxNode) -> Int {
    match n {
        Leaf(v)   -> { return 1 }
        Tagged(v) -> { return 0 }
        Empty     -> { return 0 }
    }
}

// ---------------------------------------------------------------------------
// Payload-less enum tests — EnxDir
// ---------------------------------------------------------------------------

Test EnxDirWeightNorth {
    test { return enxDirWeight(EnxDir.North) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

Test EnxDirWeightSouth {
    test { return enxDirWeight(EnxDir.South) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(2); return e }
}

Test EnxDirWeightEast {
    test { return enxDirWeight(EnxDir.East) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

Test EnxDirWeightWest {
    test { return enxDirWeight(EnxDir.West) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

// Sum weights for i=0..59: 15 each of N,S,E,W -> 15*(1+2+3+4)=150
Test EnxDirFold60 {
    test {
        var acc = 0
        var i = 0
        while i < 60 {
            let d = enxDirFor(i)
            acc = acc + enxDirWeight(d)
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(150); return e }
}

// Specific array: N,E,S,W,N -> weights 1+3+2+4+1=11
Test EnxDirSpecificArray {
    test {
        let ds: [EnxDir] = [EnxDir.North, EnxDir.East, EnxDir.South, EnxDir.West, EnxDir.North]
        var s = 0
        for d in ds {
            s = s + enxDirWeight(d)
        }
        return s
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(11); return e }
}

// enxDirFor(0)=North, weight=1
Test EnxDirSwitchIndex0 {
    test {
        let d = enxDirFor(0)
        return enxDirWeight(d)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

// enxDirFor(7): 7%4=3=West, weight=4
Test EnxDirSwitchIndex7 {
    test {
        let d = enxDirFor(7)
        return enxDirWeight(d)
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

// Count Wests in i=0..11: i%4=3 at i=3,7,11 -> 3
Test EnxDirCountWest {
    test {
        var count = 0
        var i = 0
        while i < 12 {
            let d = enxDirFor(i)
            var isWest = 0
            match d {
                West  -> { isWest = 1 }
                North -> { isWest = 0 }
                South -> { isWest = 0 }
                East  -> { isWest = 0 }
            }
            count = count + isWest
            i = i + 1
        }
        return count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

// sum i * enxDirWeight(enxDirFor(i)) for i=0..7:
// i=0:0*1=0, i=1:1*2=2, i=2:2*3=6, i=3:3*4=12,
// i=4:4*1=4, i=5:5*2=10, i=6:6*3=18, i=7:7*4=28 -> sum=80
Test EnxDirWeightedFold {
    test {
        var acc = 0
        var i = 0
        while i < 8 {
            let d = enxDirFor(i)
            acc = acc + i * enxDirWeight(d)
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(80); return e }
}

// Count North+South (weight<=2) in i=0..11: N at 0,4,8 + S at 1,5,9 = 6
Test EnxDirCountNorthSouth {
    test {
        var count = 0
        var i = 0
        while i < 12 {
            let d = enxDirFor(i)
            let w = enxDirWeight(d)
            if w <= 2 { count = count + 1 }
            i = i + 1
        }
        return count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(6); return e }
}

// Two complete cycles of N,S,E,W (8 items): 2*(1+2+3+4)=20
Test EnxDirFold8 {
    test {
        var acc = 0
        var i = 0
        while i < 8 {
            acc = acc + enxDirWeight(enxDirFor(i))
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(20); return e }
}

// Inline match in test block (var out pattern): East matches -> 3
Test EnxDirInlineMatchEast {
    test {
        let d = EnxDir.East
        var out = 0
        match d {
            North -> { out = 1 }
            South -> { out = 2 }
            East  -> { out = 3 }
            West  -> { out = 4 }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

// ---------------------------------------------------------------------------
// Payload-less enum tests — EnxPriority
// ---------------------------------------------------------------------------

Test EnxPriorityScoreLow {
    test { return enxPriorityScore(EnxPriority.Low) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

Test EnxPriorityScoreMedium {
    test { return enxPriorityScore(EnxPriority.Medium) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

Test EnxPriorityScoreHigh {
    test { return enxPriorityScore(EnxPriority.High) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

// 30 iters, 10 each of L,M,H: 10*(1+5+10)=160
Test EnxPriorityFold30 {
    test {
        var acc = 0
        var i = 0
        while i < 30 {
            let p = enxPriorityFor(i)
            acc = acc + enxPriorityScore(p)
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(160); return e }
}

// Count High in i=0..8: i%3=2 at i=2,5,8 -> 3
Test EnxPriorityCountHigh {
    test {
        var count = 0
        var i = 0
        while i < 9 {
            let p = enxPriorityFor(i)
            var isH = 0
            match p {
                High   -> { isH = 1 }
                Medium -> { isH = 0 }
                Low    -> { isH = 0 }
            }
            count = count + isH
            i = i + 1
        }
        return count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

// sum i * enxPriorityScore(enxPriorityFor(i)) for i=0..8:
// i=0:0*1=0, i=1:1*5=5, i=2:2*10=20, i=3:3*1=3, i=4:4*5=20,
// i=5:5*10=50, i=6:6*1=6, i=7:7*5=35, i=8:8*10=80 -> sum=219
Test EnxPriorityWeightedFold {
    test {
        var acc = 0
        var i = 0
        while i < 9 {
            let p = enxPriorityFor(i)
            acc = acc + i * enxPriorityScore(p)
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(219); return e }
}

// Array of priorities, fold scores: [L,M,H,L,M] = 1+5+10+1+5=22
Test EnxPriorityArrayFold {
    test {
        let ps: [EnxPriority] = [EnxPriority.Low, EnxPriority.Medium, EnxPriority.High, EnxPriority.Low, EnxPriority.Medium]
        var s = 0
        for p in ps {
            s = s + enxPriorityScore(p)
        }
        return s
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(22); return e }
}

