Test EnxSeasonCodeSpring {
    test { return enxSeasonCode(EnxSeason.Spring) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test EnxSeasonCodeSummer {
    test { return enxSeasonCode(EnxSeason.Summer) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(20); return e }
}

Test EnxSeasonCodeAutumn {
    test { return enxSeasonCode(EnxSeason.Autumn) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test EnxSeasonCodeWinter {
    test { return enxSeasonCode(EnxSeason.Winter) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(40); return e }
}

// 40 iters, 10 each: 10*(10+20+30+40)=1000
Test EnxSeasonFold40 {
    test {
        var acc = 0
        var i = 0
        while i < 40 {
            let s = enxSeasonFor(i)
            acc = acc + enxSeasonCode(s)
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1000); return e }
}

// Literal array: [Spr,Sum,Aut,Win,Spr] = 10+20+30+40+10=110
Test EnxSeasonSpecificArray {
    test {
        let ss: [EnxSeason] = [EnxSeason.Spring, EnxSeason.Summer, EnxSeason.Autumn, EnxSeason.Winter, EnxSeason.Spring]
        var acc = 0
        for s in ss {
            acc = acc + enxSeasonCode(s)
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(110); return e }
}

// Count warm seasons (code <= 20, i.e. Spring+Summer) in i=0..11: 3+3=6
Test EnxSeasonCountWarm {
    test {
        var count = 0
        var i = 0
        while i < 12 {
            let s = enxSeasonFor(i)
            let c = enxSeasonCode(s)
            if c <= 20 { count = count + 1 }
            i = i + 1
        }
        return count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(6); return e }
}

// ---------------------------------------------------------------------------
// Single-payload enum tests — EnxToken
// ---------------------------------------------------------------------------

// Num(42) -> 42
Test EnxTokenNumDirect {
    test { return enxTokenVal(EnxToken.Num(42)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

// Paren(7) -> 7*2=14
Test EnxTokenParenDirect {
    test { return enxTokenVal(EnxToken.Paren(7)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(14); return e }
}

// Op(3) -> 3*3=9
Test EnxTokenOpDirect {
    test { return enxTokenVal(EnxToken.Op(3)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(9); return e }
}

// Fold for i=0..29:
// Nums(i=0,3,6,9,12,15,18,21,24,27): vals = 0+3+6+9+12+15+18+21+24+27=135
// Parens(i=1,4,7,10,13,16,19,22,25,28): sum=145, *2=290
// Ops(i=2,5,8,11,14,17,20,23,26,29): sum=155, *3=465
// total=135+290+465=890
Test EnxTokenFold30 {
    test {
        var acc = 0
        var i = 0
        while i < 30 {
            let t = enxTokenFor(i)
            acc = acc + enxTokenVal(t)
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(890); return e }
}

// Literal array: [Num(7),Paren(3),Op(2),Num(1),Paren(5)] -> 7+6+6+1+10=30
Test EnxTokenLiteralArrayFold {
    test {
        let ts: [EnxToken] = [EnxToken.Num(7), EnxToken.Paren(3), EnxToken.Op(2), EnxToken.Num(1), EnxToken.Paren(5)]
        var s = 0
        for t in ts {
            s = s + enxTokenVal(t)
        }
        return s
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

// Indexed access via borrow helper: tokens[j] passed to enxTokenVal(borrow EnxToken)
// Array: [Num(10), Op(4), Paren(3)] -> 10+12+6=28
Test EnxTokenIndexedAccessFold {
    test {
        var ts: [EnxToken] = []
        ts.append(EnxToken.Num(10))
        ts.append(EnxToken.Op(4))
        ts.append(EnxToken.Paren(3))
        var acc = 0
        var j = 0
        while j < ts.count {
            acc = acc + enxTokenVal(ts[j])
            j = j + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(28); return e }
}

// sum (i+1)*enxTokenVal(enxTokenFor(i)) for i=0..5:
// i=0:Num(0)->0, 1*0=0
// i=1:Paren(1)->2, 2*2=4
// i=2:Op(2)->6, 3*6=18
// i=3:Num(3)->3, 4*3=12
// i=4:Paren(4)->8, 5*8=40
// i=5:Op(5)->15, 6*15=90
// total=0+4+18+12+40+90=164
Test EnxTokenWeightedFold {
    test {
        var acc = 0
        var i = 0
        while i < 6 {
            let t = enxTokenFor(i)
            acc = acc + (i + 1) * enxTokenVal(t)
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(164); return e }
}

// Inline match in test block (var out pattern)
// Num(5) -> out=5
Test EnxTokenInlineMatchNum {
    test {
        let t = EnxToken.Num(5)
        var out = 0
        match t {
            Num(v)   -> { out = v }
            Paren(v) -> { out = v * 2 }
            Op(v)    -> { out = v * 3 }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(5); return e }
}

// Inline match in test block: Op(4) -> 12
Test EnxTokenInlineMatchOp {
    test {
        let t = EnxToken.Op(4)
        var out = 0
        match t {
            Num(v)   -> { out = v }
            Paren(v) -> { out = v * 2 }
            Op(v)    -> { out = v * 3 }
        }
        return out
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(12); return e }
}

// Sum only Num values in i=0..8 (ignore Paren/Op):
// Nums at i%3=0: i=0,3,6 -> Num(0)->0, Num(3)->3, Num(6)->6 -> sum=9
Test EnxTokenSumNumsOnly {
    test {
        var acc = 0
        var i = 0
        while i < 9 {
            let t = enxTokenFor(i)
            var v = 0
            match t {
                Num(x)   -> { v = x }
                Paren(x) -> { v = 0 }
                Op(x)    -> { v = 0 }
            }
            acc = acc + v
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(9); return e }
}

// ---------------------------------------------------------------------------
// Single-payload + payload-less enum tests — EnxEvent
// ---------------------------------------------------------------------------

Test EnxEventClickDirect {
    test { return enxEventScore(EnxEvent.Click(7)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

Test EnxEventKeyDirect {
    test { return enxEventScore(EnxEvent.Key(3)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test EnxEventScrollDirect {
    test { return enxEventScore(EnxEvent.Scroll(2)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(200); return e }
}

Test EnxEventIdleDirect {
    test { return enxEventScore(EnxEvent.Idle) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

// [Click(3),Key(2),Scroll(1),Idle,Click(5),Key(1)] -> 3+20+100+0+5+10=138
Test EnxEventArrayFold {
    test {
        let es: [EnxEvent] = [EnxEvent.Click(3), EnxEvent.Key(2), EnxEvent.Scroll(1), EnxEvent.Idle, EnxEvent.Click(5), EnxEvent.Key(1)]
        var s = 0
        for ev in es {
            s = s + enxEventScore(ev)
        }
        return s
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(138); return e }
}

// Indexed access via borrow helper
// events[j] via enxEventScore(events[j])
// [Click(10), Idle, Key(3), Scroll(1)] -> 10+0+30+100=140
Test EnxEventIndexedFold {
    test {
        var events: [EnxEvent] = []
        events.append(EnxEvent.Click(10))
        events.append(EnxEvent.Idle)
        events.append(EnxEvent.Key(3))
        events.append(EnxEvent.Scroll(1))
        var acc = 0
        var j = 0
        while j < events.count {
            acc = acc + enxEventScore(events[j])
            j = j + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(140); return e }
}

// Count non-Idle events in [Click(1),Idle,Key(2),Scroll(3),Idle,Click(4)] -> 4
Test EnxEventCountNonIdle {
    test {
        let es: [EnxEvent] = [EnxEvent.Click(1), EnxEvent.Idle, EnxEvent.Key(2), EnxEvent.Scroll(3), EnxEvent.Idle, EnxEvent.Click(4)]
        var count = 0
        for ev in es {
            if enxIsIdleEvent(ev) == 0 { count = count + 1 }
        }
        return count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(4); return e }
}

// Sum only Click payloads in [Click(5),Key(2),Click(8),Idle,Click(1)]: 5+8+1=14
Test EnxEventSumClicksOnly {
    test {
        let es: [EnxEvent] = [EnxEvent.Click(5), EnxEvent.Key(2), EnxEvent.Click(8), EnxEvent.Idle, EnxEvent.Click(1)]
        var acc = 0
        for ev in es {
            acc = acc + enxClickPayload(ev)
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(14); return e }
}

// ---------------------------------------------------------------------------
// Mixed payload/payload-less enum tests — EnxStatus
// ---------------------------------------------------------------------------

Test EnxStatusDormantDirect {
    test { return enxStatusCode(EnxStatus.Dormant) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

Test EnxStatusRunningDirect {
    test { return enxStatusCode(EnxStatus.Running(42)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

// Done(15) -> 15+100=115
Test EnxStatusDoneDirect {
    test { return enxStatusCode(EnxStatus.Done(15)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(115); return e }
}

// Failed(8) -> 0-8 = -8
Test EnxStatusFailedDirect {
    test { return enxStatusCode(EnxStatus.Failed(8)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0 - 8); return e }
}

// i=0..11: enxStatusFor(i) then code:
// Dormant: i=0,4,8 -> codes 0,0,0 = 0
// Running: i=1,5,9 -> codes 1,5,9 = 15
// Done: i=2,6,10 -> codes 102,106,110 = 318
// Failed: i=3,7,11 -> codes -3,-7,-11 = -21
// total = 0+15+318-21 = 312
Test EnxStatusFold12 {
    test {
        var acc = 0
        var i = 0
        while i < 12 {
            let s = enxStatusFor(i)
            acc = acc + enxStatusCode(s)
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(312); return e }
}

// Count Running+Done (active) in i=0..11: Running=3, Done=3 -> 6
Test EnxStatusCountActive {
    test {
        var count = 0
        var i = 0
        while i < 12 {
            let s = enxStatusFor(i)
            var active = 0
            match s {
                Dormant    -> { active = 0 }
                Running(n) -> { active = 1 }
                Done(n)    -> { active = 1 }
                Failed(n)  -> { active = 0 }
            }
            count = count + active
            i = i + 1
        }
        return count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(6); return e }
}

// Sum Running payload values in i=0..11: Running at i=1,5,9 -> 1+5+9=15
Test EnxStatusRunningSum {
    test {
        var acc = 0
        var i = 0
        while i < 12 {
            let s = enxStatusFor(i)
            var v = 0
            match s {
                Running(n) -> { v = n }
                Dormant    -> { v = 0 }
                Done(n)    -> { v = 0 }
                Failed(n)  -> { v = 0 }
            }
            acc = acc + v
            i = i + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(15); return e }
}

// Indexed access via borrow helper: statusFor is called, result passed to enxStatusCode(statuses[j])
// Build [Dormant, Running(10), Done(5), Failed(3), Running(20)]
// codes: 0+10+105-3+20=132
Test EnxStatusIndexedFold {
    test {
        var statuses: [EnxStatus] = []
        statuses.append(EnxStatus.Dormant)
        statuses.append(EnxStatus.Running(10))
        statuses.append(EnxStatus.Done(5))
        statuses.append(EnxStatus.Failed(3))
        statuses.append(EnxStatus.Running(20))
        var acc = 0
        var j = 0
        while j < statuses.count {
            acc = acc + enxStatusCode(statuses[j])
            j = j + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(132); return e }
}

// ---------------------------------------------------------------------------
// EnxNode — mixed payload/payload-less (Leaf, Tagged, Empty)
// ---------------------------------------------------------------------------

Test EnxNodeLeafDirect {
    test { return enxNodeVal(EnxNode.Leaf(7)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(7); return e }
}

Test EnxNodeTaggedDirect {
    test { return enxNodeVal(EnxNode.Tagged(4)) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(40); return e }
}

Test EnxNodeEmptyDirect {
    test { return enxNodeVal(EnxNode.Empty) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(0); return e }
}

// [Leaf(5),Tagged(3),Empty,Leaf(7),Tagged(1),Empty,Leaf(2)] -> 5+30+0+7+10+0+2=54
Test EnxNodeArrayFold {
    test {
        let ns: [EnxNode] = [EnxNode.Leaf(5), EnxNode.Tagged(3), EnxNode.Empty, EnxNode.Leaf(7), EnxNode.Tagged(1), EnxNode.Empty, EnxNode.Leaf(2)]
        var s = 0
        for n in ns {
            s = s + enxNodeVal(n)
        }
        return s
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(54); return e }
}

// Indexed access via borrow helper
// [Leaf(3), Tagged(2), Empty, Leaf(10)] via enxNodeVal(nodes[j])
// 3+20+0+10=33
Test EnxNodeIndexedFold {
    test {
        var nodes: [EnxNode] = []
        nodes.append(EnxNode.Leaf(3))
        nodes.append(EnxNode.Tagged(2))
        nodes.append(EnxNode.Empty)
        nodes.append(EnxNode.Leaf(10))
        var acc = 0
        var j = 0
        while j < nodes.count {
            acc = acc + enxNodeVal(nodes[j])
            j = j + 1
        }
        return acc
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(33); return e }
}

// Count Leaf nodes in [Leaf(1),Empty,Leaf(2),Tagged(3),Leaf(4),Empty] -> 3
Test EnxNodeCountLeaves {
    test {
        let ns: [EnxNode] = [EnxNode.Leaf(1), EnxNode.Empty, EnxNode.Leaf(2), EnxNode.Tagged(3), EnxNode.Leaf(4), EnxNode.Empty]
        var count = 0
        for n in ns {
            count = count + enxIsLeaf(n)
        }
        return count
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(3); return e }
}

