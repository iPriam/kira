Test StrxClsTriBaseFee {
    test {
        let t = StrxCTriangle()
        return t.baseFee()
    }
    // inherited, not overridden -> 1
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

Test StrxClsRectBaseFee {
    test {
        let r = StrxCRect()
        return r.baseFee()
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

Test StrxClsArrTriLoop {
    test {
        var tris: [StrxCTriangle] = []
        var i = 0
        while i < 5 {
            var t = StrxCTriangle()
            t.base_len = i + 1
            tris.append(move t)
            i = i + 1
        }
        var total = 0
        var j = 0
        while j < tris.count {
            total = total + tris[j].area(2)
            j = j + 1
        }
        return total
    }
    // area(2): 1*2+2*2+3*2+4*2+5*2 = 2+4+6+8+10 = 30
    expect { let e: Result<Int, TestFailure> = Result.Ok(30); return e }
}

Test StrxClsArrTriSides {
    test {
        var tris: [StrxCTriangle] = []
        var i = 0
        while i < 5 {
            tris.append(StrxCTriangle())
            i = i + 1
        }
        var total = 0
        var j = 0
        while j < tris.count {
            total = total + tris[j].sides
            j = j + 1
        }
        return total
    }
    // 5 * 3 = 15
    expect { let e: Result<Int, TestFailure> = Result.Ok(15); return e }
}

Test StrxClsArrTriAcc {
    test {
        var tris: [StrxCTriangle] = []
        var i = 0
        while i < 5 {
            var t = StrxCTriangle()
            t.base_len = i + 1
            tris.append(move t)
            i = i + 1
        }
        var total = 0
        var j = 0
        while j < tris.count {
            total = total + tris[j].area(2) + tris[j].sides + tris[j].baseFee()
            j = j + 1
        }
        return total
    }
    // area: 30; sides: 5*3=15; baseFee: 5*1=5 -> 50
    expect { let e: Result<Int, TestFailure> = Result.Ok(50); return e }
}

Test StrxClsArrRectLoop {
    test {
        var rects: [StrxCRect] = []
        var i = 0
        while i < 4 {
            var r = StrxCRect()
            r.width = i + 1
            r.height = 2
            rects.append(move r)
            i = i + 1
        }
        var total = 0
        var j = 0
        while j < rects.count {
            total = total + rects[j].area(1)
            j = j + 1
        }
        return total
    }
    // width*2*1: 1*2+2*2+3*2+4*2 = 2+4+6+8 = 20
    expect { let e: Result<Int, TestFailure> = Result.Ok(20); return e }
}

Test StrxClsArrRectSides {
    test {
        var rects: [StrxCRect] = []
        var i = 0
        while i < 3 {
            rects.append(StrxCRect())
            i = i + 1
        }
        var total = 0
        var j = 0
        while j < rects.count {
            total = total + rects[j].sides
            j = j + 1
        }
        return total
    }
    // 3 * 4 = 12
    expect { let e: Result<Int, TestFailure> = Result.Ok(12); return e }
}

