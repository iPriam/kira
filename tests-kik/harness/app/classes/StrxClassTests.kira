Test StrxClsCounterMultiple {
    test {
        var total = 0
        var k = 0
        while k < 5 {
            var c = StrxCCounter()
            let _ = c.increment()
            let _ = c.increment()
            let _ = c.increment()
            total = total + c.getCount()
            k = k + 1
        }
        return total
    }
    // 5 * 3 = 15
    expect { let e: Result<Int, TestFailure> = Result.Ok(15); return e }
}

Test StrxClsCounterResetLoop {
    test {
        var c = StrxCCounter()
        var i = 0
        while i < 20 {
            let _ = c.increment()
            i = i + 1
        }
        let _ = c.reset()
        let _ = c.increment()
        let _ = c.increment()
        return c.getCount()
    }
    // reset then +1+1 = 2
    expect { let e: Result<Int, TestFailure> = Result.Ok(2); return e }
}

