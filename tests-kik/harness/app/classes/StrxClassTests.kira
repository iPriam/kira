Test StrxClsNodeDesc {
    test {
        var n = StrxCNode()
        n.value = 5
        return n.describe()
    }
    // 5 + 1 = 6
    expect { let e: Result<Int, TestFailure> = Result.Ok(6); return e }
}

Test StrxClsLeafDesc {
    test {
        var l = StrxCLeaf()
        l.value = 5
        return l.describe()
    }
    // 5 * 10 = 50
    expect { let e: Result<Int, TestFailure> = Result.Ok(50); return e }
}

Test StrxClsDeepLeafDesc {
    test {
        var d = StrxCDeepLeaf()
        d.value = 5
        return d.describe()
    }
    // StrxCLeaf.describe() = 5*100=500; + label=100 -> 600
    expect { let e: Result<Int, TestFailure> = Result.Ok(600); return e }
}

Test StrxClsLeafArr {
    test {
        var leaves: [StrxCLeaf] = []
        var i = 0
        while i < 4 {
            var l = StrxCLeaf()
            l.value = i
            leaves.append(move l)
            i = i + 1
        }
        var total = 0
        var j = 0
        while j < leaves.count {
            total = total + leaves[j].describe()
            j = j + 1
        }
        return total
    }
    // value=0..3: 0*10+1*10+2*10+3*10 = 0+10+20+30 = 60
    expect { let e: Result<Int, TestFailure> = Result.Ok(60); return e }
}

Test StrxClsLabelNode {
    test {
        let n = StrxCNode()
        return n.label
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

Test StrxClsLabelLeaf {
    test {
        let l = StrxCLeaf()
        return l.label
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(10); return e }
}

Test StrxClsLabelDeep {
    test {
        let d = StrxCDeepLeaf()
        return d.label
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(100); return e }
}

Test StrxClsDeepArr {
    test {
        var ds: [StrxCDeepLeaf] = []
        var i = 0
        while i < 3 {
            var d = StrxCDeepLeaf()
            d.value = i + 1
            ds.append(move d)
            i = i + 1
        }
        var total = 0
        var j = 0
        while j < ds.count {
            total = total + ds[j].describe()
            j = j + 1
        }
        return total
    }
    // value=1: 1*100+100=200; value=2: 2*100+100=300; value=3: 3*100+100=400 -> 900
    expect { let e: Result<Int, TestFailure> = Result.Ok(900); return e }
}

Test StrxClsLabelSum {
    test {
        let n = StrxCNode()
        let l = StrxCLeaf()
        let d = StrxCDeepLeaf()
        return n.label + l.label + d.label
    }
    // 1 + 10 + 100 = 111
    expect { let e: Result<Int, TestFailure> = Result.Ok(111); return e }
}

Test StrxClsLeafMutDesc {
    test {
        var l = StrxCLeaf()
        l.value = 7
        return l.describe()
    }
    // 7 * 10 = 70
    expect { let e: Result<Int, TestFailure> = Result.Ok(70); return e }
}

Test StrxClsDeepMutDesc {
    test {
        var d = StrxCDeepLeaf()
        d.value = 3
        return d.describe()
    }
    // StrxCLeaf.describe()=3*100=300; +100=400
    expect { let e: Result<Int, TestFailure> = Result.Ok(400); return e }
}

Test StrxClsNodeDescLoop {
    test {
        var total = 0
        var i = 0
        while i < 5 {
            var n = StrxCNode()
            n.value = i
            total = total + n.describe()
            i = i + 1
        }
        return total
    }
    // (0+1)+(1+1)+(2+1)+(3+1)+(4+1) = 1+2+3+4+5 = 15
    expect { let e: Result<Int, TestFailure> = Result.Ok(15); return e }
}

