Test StrxClsMixCLoop {
    test {
        let m = StrxCMix()
        var sum = 0
        var n = 0
        while n < 5 {
            sum = sum + m.cSum(n)
            n = n + 1
        }
        return sum
    }
    // n=0: 30; n=1: 32; n=2: 34; n=3: 36; n=4: 38 -> 170
    expect { let e: Result<Int, TestFailure> = Result.Ok(170); return e }
}

Test StrxClsMixWLoopMul {
    test {
        let m = StrxCMix()
        var acc = 0
        var k = 0
        while k < 4 {
            acc = acc + m.wSum() * k
            k = k + 1
        }
        return acc
    }
    // 0*13 + 1*13 + 2*13 + 3*13 = 0+13+26+39 = 78
    expect { let e: Result<Int, TestFailure> = Result.Ok(78); return e }
}

Test StrxClsMixAllFields {
    test {
        let m = StrxCMix()
        return m.vSum() + m.wSum()
    }
    // 30 + 13 = 43
    expect { let e: Result<Int, TestFailure> = Result.Ok(43); return e }
}

