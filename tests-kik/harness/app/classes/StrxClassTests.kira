Test StrxClsTrapArrOob {
    test {
        var tris: [StrxCTriangle] = []
        tris.append(StrxCTriangle())
        tris.append(StrxCTriangle())
        let _ = tris[99].sides
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxClsTrapDivZero {
    test {
        let a = 5
        let b = 0
        return a / b
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxClsTrapModZero {
    test {
        let a = 10
        let b = 0
        return a % b
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}

Test StrxClsTrapLeafArrOob {
    test {
        var leaves: [StrxCLeaf] = []
        var i = 0
        while i < 3 {
            leaves.append(StrxCLeaf())
            i = i + 1
        }
        let _ = leaves[10].label
        return 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Error(TestFailure.Runtime("")); return e }
}
