// StrxClassTests.kira — deep class/inheritance coverage for `kira test`.
// PREFIX: strx / Strx  (all top-level names use this prefix).
//
// PARITY RULE: no inherited base method ever calls self.<m>() where a
// descendant overrides <m>. Super-calls use only parent-qualified
// Parent.method() inside overrides. Inherited methods read only self fields
// or call parent-qualified methods, which is consistent across all backends.

// ---------------------------------------------------------------------------
// H1: Three-level single inheritance, field-default overrides, super-calls
// ---------------------------------------------------------------------------

class StrxCBase {
    var points: Int = 10
    let rank: Int = 1

    // reads only self fields -> consistent on any subclass instance
    function score() -> Int {
        return self.points * self.rank
    }

    function tier() -> Int {
        return 1
    }
}

class StrxCSilver extends StrxCBase {
    override let rank = 3

    override function tier() -> Int {
        return 2
    }

    // parent-qualified super-call
    function bonus() -> Int {
        return StrxCBase.score() + self.points
    }
}

class StrxCGold extends StrxCSilver {
    override let rank = 7

    override function tier() -> Int {
        return 3
    }
}

// ---------------------------------------------------------------------------
// H2: Multiple inheritance with same-named members; parent-qualified dispatch
// ---------------------------------------------------------------------------

class StrxCX {
    let v: Int = 10

    function weight() -> Int {
        return 5
    }

    function compute(n: Int) -> Int {
        return n + 10
    }
}

class StrxCY {
    let v: Int = 20

    function weight() -> Int {
        return 8
    }

    function compute(n: Int) -> Int {
        return n + 20
    }
}

class StrxCMix extends StrxCX, StrxCY {
    function vSum() -> Int {
        return StrxCX.v + StrxCY.v
    }

    function wSum() -> Int {
        return StrxCX.weight() + StrxCY.weight()
    }

    function cSum(n: Int) -> Int {
        return StrxCX.compute(n) + StrxCY.compute(n)
    }
}

// ---------------------------------------------------------------------------
// H3: Array of leaf instances; overridden method dispatch in loops
// ---------------------------------------------------------------------------

class StrxCShape {
    let sides: Int = 0

    function area(k: Int) -> Int {
        return 0
    }

    // never overridden -> safe to call from any context
    function baseFee() -> Int {
        return 1
    }
}

class StrxCTriangle extends StrxCShape {
    override let sides = 3
    var base_len: Int = 1

    override function area(k: Int) -> Int {
        return self.base_len * k
    }
}

class StrxCRect extends StrxCShape {
    override let sides = 4
    var width: Int = 1
    var height: Int = 1

    override function area(k: Int) -> Int {
        return self.width * self.height * k
    }
}

// ---------------------------------------------------------------------------
// H4: Parameterized override + super-call chain, three levels
// ---------------------------------------------------------------------------

class StrxCVehicle {
    let base: Int = 5

    function cost(km: Int) -> Int {
        return self.base + km
    }
}

class StrxCCar extends StrxCVehicle {
    override let base = 10

    override function cost(km: Int) -> Int {
        return self.base + km * 2
    }
}

class StrxCTruck extends StrxCCar {
    override let base = 15

    // super-call via parent-qualified
    override function cost(km: Int) -> Int {
        return StrxCCar.cost(km) + 3
    }
}

// ---------------------------------------------------------------------------
// H5: Stateful class with mutable field, inheritance of non-conflicting methods
// ---------------------------------------------------------------------------

class StrxCCounter {
    var count: Int = 0

    function increment() -> Int {
        self.count = self.count + 1
        return self.count
    }

    function getCount() -> Int {
        return self.count
    }

    function reset() -> Int {
        self.count = 0
        return 0
    }
}

class StrxCSmartCounter extends StrxCCounter {
    var step: Int = 2

    function incrementBy(n: Int) -> Int {
        self.count = self.count + n
        return self.count
    }

    function addStep() -> Int {
        self.count = self.count + self.step
        return self.count
    }
}

// ---------------------------------------------------------------------------
// H6: Three-level hierarchy, field override chain, super-call in describe
// ---------------------------------------------------------------------------

class StrxCNode {
    var value: Int = 0
    let label: Int = 1

    function describe() -> Int {
        return self.value + self.label
    }
}

class StrxCLeaf extends StrxCNode {
    override let label = 10

    override function describe() -> Int {
        return self.value * self.label
    }
}

class StrxCDeepLeaf extends StrxCLeaf {
    override let label = 100

    // super-call: uses StrxCLeaf.describe() on self (self.label=100)
    override function describe() -> Int {
        return StrxCLeaf.describe() + self.label
    }
}

