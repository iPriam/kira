Test StrxClsH1Loop {
    test {
        let a = StrxCBase()
        let s = StrxCSilver()
        let g = StrxCGold()
        var acc = 0
        acc = acc + a.score() + a.tier()
        acc = acc + s.score() + s.tier()
        acc = acc + g.score() + g.tier()
        return acc
    }
    // (10+1) + (30+2) + (70+3) = 11+32+73 = 116
    expect { let e: Result<Int, TestFailure> = Result.Ok(116); return e }
}

