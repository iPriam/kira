class HandlerBox {
    let onDone: () -> Void
    let onValue: (Int) -> Void
}

function invokeLater(callback: borrow () -> Void) {
    callback()
    return
}

function sayHi() {
    print("hi")
    return
}

function trigger(box: borrow HandlerBox) {
    box.onDone()
    box.onValue(42)
    return
}

@Main
function main() {
    let callback: () -> Void = sayHi
    let printer: (Int) -> Void = { value in
        print(value)
    }

    callback()
    printer(7)
    invokeLater(callback)

    let box: HandlerBox = HandlerBox(move callback, move printer)
    trigger(box)
    return
}
