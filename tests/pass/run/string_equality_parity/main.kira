// Regression: executable String content equality (`==` / `!=`). Previously
// rejected as non-executable (KIR001); now lowered on every backend (VM compares
// bytes directly; LLVM compares length + memcmp(min) inline). Asserts vm/llvm/
// hybrid agree.
function pick(i: Int) -> String {
    if i == 0 { return "alpha" }
    return "beta"
}

@Main
function main() {
    print("alpha" == "alpha")        // true
    print("alpha" == "beta")         // false
    print("alpha" != "beta")         // true
    print("" == "")                  // true
    print("a" == "ab")               // false (prefix, different length)
    print(pick(0) == "alpha")        // true (computed string)
    print(pick(1) == pick(1))        // true
    return
}
